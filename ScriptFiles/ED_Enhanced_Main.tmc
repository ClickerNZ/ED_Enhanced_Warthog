
	//--------------------------------------------------------------------------------------//
	//		  CMDR Clicker's Elite Dangerous Enhanced Thrustmaster TARGET Script			//
	//																						//
	//		   Contact:  https://forums.frontier.co.uk/members/clicker.19039/				//
	//--------------------------------------------------------------------------------------//

	//							THRUSTMASTER WARTHOG REQUIRED								//

	// This file:	ED_Enhanced_Main.tmc	 		v510.1					// New Minor Version
	// Supports:	Elite Dangerous 				v4.3.1.0				// Does not support Legacy Horizons
	// Requires:	TARGET 							v3.0.25.603				// https://support.thrustmaster.com/
	//				Joystick firmware				v12
	//				Throttle firmware 				v23
	//				AVA firmware					v2.07					// NOTE: AVA users opting to stay on older firmware 
	//																		// need to use TARGET V3.0.24.618_rev1
		
	// Refer Change Log.txt in parent folder

	//	LEGEND:	This script package calls functions using the naming convention set out in the table 
	//			below and within the following support files
	// ==============================================================================================
	// fnName()								refer to ED_Functions file
	// initName()							refer to ED_Initialise file
	// stfnName()							refer to ED_StateTracker file
	// tgName()								refer to ED_Toggles file
	// mName								refer to ED_Macros file
	// MapKey statements					refer to ED_MapKeyAssignment file
	// Global State and Boolean Defines		refer to ED_ScriptDefines file
	// Global Game Key Bind Defines			refer to ED_GameBindings file 
	// Global Script Variables				refer to ED_GlobalVars file
	// User Configuration Settings			refer to ED_UserSettings file
	// ==============================================================================================

/*
	PREFACE

	This script is provided as is and without any warranties, explicit or implied.

	This package contains a single required '.tmc' file (this is it), a '.ttm' which defines MANY constants and variables used by the rest
	of the script. The whole package is coded within multiple '.tmh' files in order to (hopefully) make the code easier to follow and maintain.

	The included change log file is no longer used to document where I've added features (intended and unintended!) 
	Please refer to the github repository to understand changes made.
	
	A sample Windows batch file is included in the package to assist in lanching this script the game itself and any attendant
	apps you may wish to use at run time.

	Indexes near the top of each code file should assist in finding functions of interest.

	This script serves to create additional functionality and immersion within the game as well as serve as a reference on how better to utilise
	TARGET script beyond what is supplied in the basic scripting guide provided by Thrustmaster.

	Enjoy.

	CMDR Clicker	
*/

	// START

	// -------------- //
	// included files //
	// -------------- //

	include "target.tmh"

	// "include target.tmh" is mandatory for most, if not all .tmc files.
	// 		when loaded, target.tmh includes --> "defines.tmh" and "hid.tmh"
	// 		when loaded, hid.tmh includes --> "sys.tmh"
	//		...this ensures these critical THRUSTMASTER TARGET script files are loaded in the correct order

	//      The above 4x .tmh files are bundled with the TARGET software and will be replaced each update.

	/////////////////////////////////////////////////////////////////////////////
	///                                                                       ///
	///    !!! DO NOT EDIT TARGET.TMH, DEFINES.TMH, SYS.TMH OR HID.TMH !!!    ///
	///                                                                       ///
	/////////////////////////////////////////////////////////////////////////////

	include "ED_ScriptDefines.ttm"			// The order that these files are 'included' matters
	include "ED_GameBindings.ttm"
	include "ED_GlobalVars.tmh"
	include "ED_UserSettings.tmh"
	include "ED_Macros.tmh"
	include "ED_Initialise.tmh"
	include "ED_Functions.tmh"
	include "ED_StateTracker.tmh"
	include "ED_Toggles.tmh"
	include "ED_MapKeyAssignment.tmh"

//- Excluded from github - remove prior to publishing
//-	DEBUG	+++++
	include "ED_Development.tmh"
//-	DEBUG	+++++
		
	//--------------//
	// Main Program //
	//--------------//
	
	int main() {
	
		printf("\x0a\++	Initialise hardware	...	Start	++\x0a\x0a");			// Eliminates error messages relating to unfound devices
																				// Check target.tmh alias list
		
		// We will get some "device not found messages as we do not exclude devices that this script will support but may not be connected
		
		Exclude(&HCougar);
		Exclude(&T16000);
		Exclude(&T16000L);
		Exclude(&TWCSThrottle);
		Exclude(&LMFD);
		Exclude(&RMFD);
		Exclude(&A320Pilot);
		Exclude(&A320Copilot);
		Exclude(&TCAQuadrant12);
		Exclude(&TCAQuadrant34);
		Exclude(&TCAQBoeing12);
		Exclude(&TCAQBoeing34);
		Exclude(&TCAYokeBoeing);
		Exclude(&ViperTQS);		
		Exclude(&ViperBBox);	
		Exclude(&TCASidestickXPilot);
		Exclude(&TCASidestickXCopilot);
		Exclude(&FarmStickRight);
		Exclude(&FarmStickLeft);
		Exclude(&FarmStickXboxRight);
		Exclude(&FarmStickXboxLeft);
		Exclude(&AVA_F16L);
		Exclude(&AVA_F18L);
		Exclude(&Sol_F16);
		Exclude(&Sol_F16L);
		Exclude(&Sol_F18);
		Exclude(&Sol_F18L);
		Exclude(&Sol_SolR);
		Exclude(&Sol_SolRL);
		Exclude(&FarmStickPSRight);
		Exclude(&FarmStickPSLeft);
		Exclude(&Sol_Throttle);					// Looks to use same mapfile as TWCSThrottle 

		if(Init(&EventHandle)) return 1;
				
				
	// ------------------------------------------------------------ //
	// Initialise Hardware, LEDs, Software, variables and functions //
	// ------------------------------------------------------------ //
		
		printf("\x0a\++	Connect our controllers ... \x0a");
		CheckControllers();														// Refer ED_Initialise.tmh
		
		SetShiftButton(&MyJoystick, S3, &MyThrottle, PSF, PSB);					// ** DO NOT TOUCH **  Joystick Nosewheel Switch (S3) = IO, Throttle pinky switch (PSF/PSB) = UMD

		SetKBRate(PulseTime, DelayTime);										// Basic Settings 	(See ED_ScriptDefines.tmh)
		SetKBLayout(KBLayout);													//					(See ED_ScriptDefines.ttm)

		fnPIPMode(RESET);														// Reset PIPMode before calling stfnMyStates(LOAD). Refer ED_UserSettings.tmh to set your preferred default PIP Mode
																				
		initUserSettings(0);													// Save default user settings. On the fly customisation available for most settings.
		
		printf("\x0a\++	Load MyStates from file...\x0a");
		stfnMyStates(LOAD);														// Load script status variables (not covered in status.json) and modified User Settings 
		
		fnLEDBrightness();														// Set initial LED Brightness levels

		printf("++	Initialise Sound enhancement functions (if ENABLED)...\x0a\x0a");
		initTextToSpeech();														// Initialise Text-To-Speech engine
		initSoundFX();															// Initialise Sound Effects engine

		printf("\x0a\++	Initialise Macro Chains...\x0a");
		initMacroChains();														// Initialise Custom Macros (See ED_Macros.tmh)

//- Excluded from github - remove prior to publishing
//-	DEBUG	+++++
		initDevMacros();														// Initialise any development macros (refer ED_Development.tmh)
//-	DEBUG	+++++
		
	// -------------------------- //
	// Initialise Flight controls //
	// -------------------------- //

		printf("\x0a\++	Initialise Joystick, Throttle and Rudder\x0a");

		fnStartupMapKeyMode();													// Enable Joystick and Throttle buttons and switches

		initJoystickAxis();
		initThrottleAxis();
		initSliderAxis();
		initSlewAxis();
		initRudderAxis();
		initCurves(NONE, PRINT, YES, FALSE);									// Parameters: Curve profile=NONE, Print to console=NO, TTS Announce= YES, Save Curves = FALSE 

		printf("\x0a\++	Initialise Hardware	...	Complete	++\x0a\x0a");
		
	// ----------------- //
	// Check Game State  //
	// ----------------- //

		printf("\x0a\++	Check Game state ...\x0a");
		
		stfnStartCheck();														// Check for vital files and game start. Bootstrap script execution.
		
		if (DEBUG > 0) {
			printf("\x0a!!	DEBUG MODE = %s\x0a", DEBUGMODE);
			printf("!!	DEBUG: Debug Function = %s\x0a", DebugFunction);		// Refer fnDEBUG() 
		}
	}	
	
	// end of int main()	

	// ------------ //
	// EventHandle  //
	// ------------ //

	int EventHandle(int type, alias o, int x) {

		DefaultMapping(&o, x);
		
	}
		
	// END
