
	//--------------------------------------------------------------------------------------//
	//		  CMDR Clicker's Elite Dangerous Enhanced Thrustmaster TARGET Script			//
	//--------------------------------------------------------------------------------------//

	//							This file: ED_ScriptDefines.ttm								//

	// Below are the global, static, state and boolean definitions used within the script package
	// Also contains global status.json integer variable flags for ease of maintenance and readability

						//  -- WARNING --  //

	// Do not define a variable as 'ALT+F4' (L_ALT+USB[0x3D] or R_ALT+USB[0x3D])
	// Why??? - PULSE an ALT+F4 to the current active window will close it!

						//   -- NOTES --   //

	// Assigning ALT+F3 results in a 'brrringg' noise in TARGET Script Editor/GUI and is not advised

	// START

	define KBLayout 				KB_ENG					// Default Keyboard Layout. Options = KB_FR or KB_GER
	
	define	ControllerCheck			ENABLED					// ENABLED:		Abort script if compatible Joystick or Throttle not found during CheckControllers() function at script start

	//---------//
	// Timings //
	//---------//

	// These delay settings affect how fast the script executes key press sequences etc.
	// If you find the macros are dropping characters, then the delay is too short.
	// "LongPress" is a personal setting. I find a half second is about right for me when using with TEMPO.
	
	define 	PulseTime 				35						// PULSE+ Delay time (ms) - Used as key-hold-down time.
	define 	DelayTime 				100						// D() Delay time 	 (ms) - Used in macros as the time between releasing one key and pressing the next
	define 	LongPress	 			500						// Tempo Delay 		 (ms) - Used in Tempos. ie hold switch/button for 0.5 seconds for alternate function

	// Verify timers reqd for the below 
	define 	CompoScanDelay			5000					// Composition scanner	'hold-trigger' timer (5 seconds)
	define	DataLinkScanDelay		5000					// Datalink scanner		'hold-trigger' timer (5 seconds)
	define	KWSDelay				5000					// Kill Warrant Scanner	'hold-trigger' timer (5 seconds)
	define 	DiscoDelay				6100					// Discovery scanner	'hold-trigger' timer (6.1 seconds)	- VERIFIED 
	define	WakeScanDelay			10100					// Wake Scanner			'hold-trigger' timer (10.1 seconds)	- VERIFIED
	define	ManifestScanDelay		9000					// Manifest Scanner		'hold-trigger' timer (9 seconds)
	
	//-------------------//
	// PIPMAPPER DEFINES //
	//-------------------//

	define SYS						1						// Used in fnPIPMapper for managing System  PIPs (see EDFunctions.tmh) (DO NOT modify!)
	define ENG						2						// Used in fnPIPMapper for managing Engine  PIPs (see EDFunctions.tmh) (DO NOT modify!)
	define WEP						3						// Used in fnPIPMapper for managing Weapon  PIPs (see EDFunctions.tmh) (DO NOT modify!)
	define MID						4						// Used in fnPIPMapper for managing Balance PIPs (see EDFunctions.tmh) (DO NOT modify!)

	//------------------------------//
	// REXEC and AutoRepeat Handles //
	//------------------------------//

	define hPWS						0						// Used in ED_Functions.tmh						- PWS fire option on primary/secondary trigger
	define hReadStatusJson			1						// Used in ED_StateTracker.tmh					- main read ststus.json background loop
	define hSRStrobe				2						// Used in ED_Toggles.tmh						- Silent Running Strobe
	define hFSDCharge				3						// Used in ED_Toggles.tmh & ED_Functions.tmh	- FSD Charge detection
	define hSoundFX					4						// Used in ED_MapKeyAssignment.tmh 				- PSF & PSB reminder sound
	define hBeepFX					5						// Used in ED_Toggles.tmh						- Reverse thrust
	define hReadMyJournalData		6						// Used in ED_StateTracker.tmh					- main read MyJournalData.json background loop
	define hTerrain					7						// 
	
	//----------------------------------------------------------------------//
	// SCRIPT BOOLEAN and STATE DEFINES										//
	//----------------------------------------------------------------------//
			
	define OFF						0
	define ON						1
	
	define LOG						2						// DEBUG Levels
	define VERBOSE					3						// DEBUG Levels

	define STROBE					2						// Used in tgSilentRunning()
	
	define TRUE						1
	define FALSE					0
	
	define YES						1
	define NO						0
	
	define ENABLED					1
	define DISABLED					0
	
	define SET						1
	define RESET					0
	
	define NEXT						1
	define PREVIOUS					2
	
	define HOLD						0
	define PUSH						1
	
	define EXIT						0
	define ENTER					1

	define BASIC					0
	define FULL						1
	define CUSTOM					2
	
	define DEPLOY					1
	define RETRACT					0
	define RECOVER					0
	
	define NOCHANGE					0
	define INCREASE					1
	define DECREASE					2
	
	define FLOAT					0
	define INTEGER					1
	define STRING					2
	define BOOLEAN					4
	
	define NUL						0						// Should be '\x0' ??? so we can use to terminate strings?
	define NONE						0						// used for initCurves()
	define MILD						1						// used for initCurves()
	define MEDIUM					2						// used for initCurves()
	define SLOW						3						// used for initCurves()
	define SLOWEST					4						// used for initCurves()

	define NOPRINT					0						// suppress console message, or...
	define PRINT					1						// ...don't

	define LOAD						0						// used in stfnMyStates()	
	define SAVE						1						// used in stfnMyStates()

	//---------------//
	// DEBUG DEFINES //										// Options = OFF (0), ON (1),  LOG (2), VERBOSE (3). 
	//---------------//

//	int		DEBUG					= OFF;					// InputCMD disabled. Many DEBUG outputs supressed
	int		DEBUG					= ON;					// Development/DEBUG Mode. example InputCMD enabled 
