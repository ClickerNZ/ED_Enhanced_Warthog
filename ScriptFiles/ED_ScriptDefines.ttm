	//---------------//
	// MODULES MASKS //					// BCD encoded value within 'Modules' key in MyJournalData.json 
	//---------------//					// These are updated by the PS_Journal helper script each time the 'Loadout' event appears in the ED Journal 

	define ED_SCOPresent				0x0000000000000001	// 1	- Supercruise Overdrive Capable Frame Shift  Drive is installed 
	define ED_FighterPresent			0x0000000000000002	// 2	- Fighter Bay (not actual fighter is installed on ship 
	define ED_SRVPresent				0x0000000000000004	// 4	- SRV Bay is installed on ship
	define ED_HeatsinkPresent			0x0000000000000008 	// 8	- Heatsink Launcher is installed on ship
	
	define ED_ChaffLauncherPresent		0x0000000000000010	// 16	- Chaff Launcher is installed on ship 
	define ED_SCBPresent				0x0000000000000020 	// 32	- Shield Cell Bank is installed on ship 
	define ED_ECMPresent				0x0000000000000040 	// 64	- Electronic Counter Measures installed on ship
	define ED_LimpetPresent				0x0000000000000080	// 128	- Limpet controller installed on ship

	//-----------------------------------//
	//  Corresponding MODULES Variables  //
	//-----------------------------------//

	int Modules					=	0;						//  Read from MyJournalData.json 
//-	int oldModules				=	0;						//	Track when changed via stfnProcessMyJournalData()
//-															// Read and decode 'Modules' each time Modules != oldModules
	int	fSCOPresent				=	0;
	int fFighterPresent			= 	0;
	int fSRVPresent				=	0;	
	int fHeatsinkPresent		=	0;
	int	fChaffLauncherPresent	=	0;
	int fSCBPresent				=	0;
	int fECMPresent				=	0;
	int fLimpetPresent			=	0;

