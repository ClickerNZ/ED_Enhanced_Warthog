
	//--------------------------------------------------------------------------------------//
	//		  CMDR Clicker's Elite Dangerous Enhanced Thrustmaster TARGET Script			//
	//--------------------------------------------------------------------------------------//

	//									WARTHOG REQUIRED									//

	//							This file: ED_MapKeyAssignment.tmh							//

	// Contains MapKey Statements for all button and switch actions
	// Contains MapKey Statements to announce via TextToSpeech and printf to console for each button or switch action (training mode)

	/*
	Index:		FUNCTION
	Line   33: 	int LiveKeyMap()
	Line   38:		Joystick Triggers
	Line  271:		Throttle Lever Switches
	Line  431:		Throttle Base Buttons
	Line  700: 	int TrainingKeyMap()
	Line  705:		Joystick Triggers
	Line  920:		Throttle Lever Switches
	Line 1079:		Throttle Base Buttons 
	*/

	// START

	// -------------------------- //
	//  KeyMaps for Running Game  //
	// -------------------------- //

	// FUNCTION:	This MapKey set is called from fnGameStarted() when we detect Game is running
	
	int LiveKeyMap() {
	
	// //////////////////////////////////////// //
	// //////////////////////////////////////// //
	//											//
	// Map Joystick triggers, switches and hats //
	//											//
	// //////////////////////////////////////// //
	// //////////////////////////////////////// //

		// Include MapKey for everything.
		// Include MapKeyR only where used.
				
	//	(Gun Trigger - Primary Fire)
	//	----------------------------

		if (MapKeyProfile == BASIC) {			// ...use BASIC profile settings							// MapKeyProfile is set within ED_UserSettings.tmh
			MapKey(&MyJoystick, TG1, PrimaryFire);
		}
		else {									// ...use FULL profile settings 
			MapKeyUMD(&MyJoystick, TG1,			// (Gun Trigger - Stage 1)
				EXEC("tgTriggerMode(1);"),																	// U - Increment trigger mode for shifted Primary Fire
				EXEC("fnAdvFireControl(0);"),																// M - Default Primary Fire action
				EXEC("fnAdvFireControl(1);")																// D - Shifted Primary Fire action
				);
				
			MapKeyRUMD(&MyJoystick, TG1,			// TG1 RELEASE
				0,																							// U -
				PrimaryFire,																				// M - Release trigger
				0																							// D -			
				);
		}
				
		MapKey(&MyJoystick, TG2, 0);				// (Gun Trigger - Stage 2)								// <not currently used>

	//	(Master Mode Control Button)
	//	----------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, S1, PULSE+DeployHardpoints);
		}
		else {		
			MapKeyUMD(&MyJoystick, S1,
				EXEC("tgHUDMode(0);"),																		// U - Toggle - Analysis/Combat Mode
				EXEC("tgHardpoints();"),																	// M - Deploy/Retract Hard-points
//-				EXEC("tgXAxis(SET);")																		// D - Toggle Joystick X-Axis between Roll and Yaw
				EXEC("tgHUDMode(0);")																		// D - Toggle - AutoHUD
				);
		}
	
	//	(Weapons Release Button - Secondary Fire)
	//	-----------------------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, S2, SecondaryFire);
		}
		else {		
			MapKeyUMD(&MyJoystick, S2,
				EXEC("tgTriggerMode(2);"),																	// U - Swap trigger action between timed and press-to-fire/press-to-stop
				EXEC("fnAdvFireControl(2);"),																// M - Default Secondary Fire action
				EXEC("fnAdvFireControl(3);")																// D - Shifted Secondary Fire action
				);
				
			MapKeyRUMD(&MyJoystick, S2,				// S2 RELEASE
				0,																							// U -
				SecondaryFire,																				// M - Release trigger 
				0																							// D -
				);
		}
	
	//	(Nosewheel Steering Button)
	//	---------------------------

		MapKey(&MyJoystick, S3, 0);																			//  ** DO NOT TOUCH ** Used as ShiftButton for IOUMD

	//	(Joystick Pinky Lever Switch)
	//	-----------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, S4, PULSE+FlightAssist);
		}
		else {		
			MapKeyUMD(&MyJoystick, S4,
				EXEC("tgEnhancedFAOFF(1)"),																	// U - Engage JSMouseEmulation
				EXEC("tgEnhancedFAOFF(0);"),																// M - TOGGLE: FA-OFF/ON
				EXEC("tgXAxis(SET);")																		// D - Toggle Joystick X-Axis between Roll and Yaw
				);
		}

	//	China Hat (Trim Switch)
	//	-----------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, H1U, PULSE+NextFireGroup);
			MapKey(&MyJoystick, H1D, PULSE+PrevFireGroup);
			MapKey(&MyJoystick, H1L, PULSE+LandingGear);
			MapKey(&MyJoystick, H1R, PULSE+ShipLights);
		}
		else {		
			MapKeyUMD(&MyJoystick, H1U,
				EXEC("tgFSSMode();"),																		// U - Toggle FSS Mode
				PULSE+NextFireGroup,																		// M - Select Next Fire Group
				PULSE+DSSModeOFF																			// D - Toggle DSSMode
				);
	
			MapKey(&MyJoystick, H1D, PULSE+PrevFireGroup);													// Select Previous Fire Group
		
			MapKeyUMD(&MyJoystick, H1L,
				EXEC("tgLandingGear(2);"),																	// U - Toggle AutoGearUP Setting	(refer ED_UserSettings.tmh)
				TEMPO(0, EXEC("tgLandingGear(0);"), LongPress),												// M - Long Press = Toggle Landing Gear (avoids accidental toggle)
				EXEC("tgLandingGear(3);")																	// D - Toggle AutoGearDOWN Setting	(refer ED_UserSettings.tmh)
				);
		
			MapKeyUMD(&MyJoystick, H1R,
				EXEC("tgLights(1);"),																		// U - Turn on Night Vision
				TEMPO(0, EXEC("tgLights(0);"), LongPress),													// M - Long Press = Toggle Ship Lights (avoids accidental toggle)
				EXEC("tgLights(2);")																		// D - Toggle AutoLandingLights setting (refer ED_UserSettings.tmh)
				);
		}
		
	//	(Target Management Switch)		// Target Designator
	//	--------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, H2U, PULSE+SelectTargetAhead);
			MapKey(&MyJoystick, H2D, PULSE+SelectHighestThreat);
			MapKey(&MyJoystick, H2L, PULSE+SelectNextShip);
			MapKey(&MyJoystick, H2R, PULSE+SelectNextHostileShip);
		}
		else {		
			MapKeyUMD(&MyJoystick, H2U,
				EXEC("tgPlanetView();"),																	// U - Toggle - Front/Back view of planet
				PULSE+SelectTargetAhead,																	// M - Target ahead
				PULSE+SelectTargetAhead																		// D - Target ahead
				);
				
			MapKeyUMD(&MyJoystick, H2D,
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// U -
				PULSE+SelectHighestThreat,																	// M - default - Target highest threat
				PULSE+WingmanTarget																			// D - Select currently selected wing-man's target
				);
				
			MapKeyUMD(&MyJoystick, H2L,
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// U -
				PULSE+SelectNextShip,																		// M - default - Cycle selection of Next Ship
				SEQ(PULSE+SelectWingman1, PULSE+SelectWingman2, PULSE+SelectWingman3)						// D - Cycle selection of Wing-men
				);
				
			MapKeyUMD(&MyJoystick, H2R,
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// U -
				PULSE+SelectNextHostileShip,																// M - default - Cycle selection of Next Hostile
				PULSE+WingmanNavLock																		// D - Select currently selected wing-man's NAV target
				);
		}
	
	//	(Data Management Switch)		// Power (PIP) Management
	//	------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, H3U, PULSE+PowerEng);
			MapKey(&MyJoystick, H3D, PULSE+BalancePower);		
			MapKey(&MyJoystick, H3L, PULSE+PowerSys);			
			MapKey(&MyJoystick, H3R, PULSE+PowerWep);
		}
		else {
			MapKeyUMD(&MyJoystick, H3U, 
				PULSE+FighterAttack,																		// U - Attack my target 
				EXEC("fnPIPManager(ENG);"),																	// M - Engine focussed PIPs 
				PULSE+FighterAttack																			// D - PLACEHOLDER
			);
			MapKeyUMD(&MyJoystick, H3D, 
				PULSE+FighterNoFire,																		// U - Follow me. hold fire
				PULSE+BalancePower,																			// M - Balance PIP sequence
				PULSE+FighterHold																			// D - Stop
			);
			MapKeyUMD(&MyJoystick, H3L, 
				PULSE+FighterDefend,																		// U - Defend me 
				EXEC("fnPIPManager(SYS);"),																	// M - System focussed PIPs
				PULSE+FighterFollow																			// D - Follow me 
			);
			MapKeyUMD(&MyJoystick, H3R, 
				PULSE+FighterAggr,																			// U - Engage at will
				EXEC("fnPIPManager(WEP);"),																	// M - Weapon focussed PIPs
				PULSE+FighterAggr																			// D - PLACEHOLDER
			);
		}

	//	(Countermeasures Management Switch)		// Countermeasures and camera/FSS Zoom
	//	-----------------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, H4U, PULSE+UseShieldCell);
			MapKey(&MyJoystick, H4D, PULSE+DeployHeatSink);
			MapKey(&MyJoystick, H4L, ChargeECM);
			MapKey(&MyJoystick, H4R, PULSE+FireChaff);
			MapKey(&MyJoystick, H4P, EXEC("fnTextToSpeech(\"Not mapped\");"));			
		}
		else {
			MapKeyUMD(&MyJoystick, H4U,
				EXEC("fnAdvancedSCB(2);"),																	// U - Double Bank + 1 Heatsink
				TEMPO(EXEC("fnAdvancedSCB(0);"), EXEC("fnAdvancedSCB(1);"), LongPress),						// M - Fire Shield Cell Bank
				CameraZoomIn																				// D - Camera/FSS Zoom - IN
				);
				
			MapKeyUMD(&MyJoystick, H4D,
				EXEC("fnHeatsink(1);"),																		// U - Toggle AutoHeatsink setting (refer ED_UserSettings.tmh
				EXEC("fnHeatsink(0);"),																		// M - Fire Heat Sink
				CameraZoomOut																				// D - Camera/FSS Zoom - OUT
				);
	
			MapKeyUMD(&MyJoystick, H4L,
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// U -
				EXEC("if (fECMPresent){ActKey(KEYON+ChargeECM); printf(\"! ECM Charging...\");}	else {fnVPOutput(\"ECM Module not installed in ship\");}"),	// M - Charge ECM (Electronic Counter Measures)
				CameraBlurOut																				// D - Camera Blur - OUT
				);
	
			MapKeyRUMD(&MyJoystick, H4L,				// RELEASE
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// RU - 
				EXEC("ActKey(ChargeECM); printf(\"Fired !\\x0a\");"),										// RM - Fire ECM when trigger is released
				EXEC("fnTextToSpeech(\"Not mapped\");")														// RD - 
				);
	
			MapKeyUMD(&MyJoystick, H4R,
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// U -
				EXEC("fnChaff();"),																			// M - Fire Chaff
				CameraBlurIn																				// D - Camera Blur - IN
				);
				
			MapKeyUMD(&MyJoystick, H4P,
				EXEC("fnPIPMode(RESET);"),																	// U - Reset PIPMode 
				EXEC("fnPIPMode(NEXT);"),																	// M - Increment PIPMode
				EXEC("fnPIPMode(PREVIOUS);")																// D - Decrement PIPMode 
				);
		}
			
	// //////////////////////////////////// //
	// //////////////////////////////////// //
	//										//
	// Map Throttle LEVER switches and hats //
	//										//
	// //////////////////////////////////// //
	// //////////////////////////////////// //
	
	//	(Slew Control Button)		// Miscellaneous
	//	---------------------
		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, SC, PULSE+ResetHeadOrientation);
		}
		else {
			MapKeyUMD(&MyThrottle, SC,
				PULSE+ShowConnectionStatus,																	// U - Display Bandwidth. Alt = "m_ShowGameStats", or "ShowFrameRate"
				PULSE+ResetHeadOrientation,																	// M - default - reset Headlook centre
				PULSE+ShowFramerate																			// D - Display GPU frame rate. Alt = "m_ShowGameStats", or "ShowConnectionStatus"
				);
		}	
	//	(Left Throttle Button)	// Headlook On/Off / External Camera
	//	----------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, LTB, PULSE+LookOnOff);
		}
		else {
			MapKeyUMD(&MyThrottle, LTB, 
				EXEC("tgExtCamera();"),																		// U - Turn External camera On/Off
				PULSE+LookOnOff,																			// M - Toggle Headlook On/Off
				EXEC("fnTextToSpeech(\"Not mapped\");")														// D - 
				);
		}
	
	//	(Pinky Switch)		// Shift Modifier Switch
	//	--------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, PSF, 0);																	//  ** DO NOT TOUCH ** Used as ShiftButton for IOUMD
			MapKey(&MyThrottle, PSM, 0);																	//  ** DO NOT TOUCH ** Used as ShiftButton for IOUMD
			MapKey(&MyThrottle, PSB, 0);																	//  ** DO NOT TOUCH ** Used as ShiftButton for IOUMD
		}
		else {
			MapKey(&MyThrottle, PSF, REXEC(hSoundFX, 3000, "fnSoundFX(\"boop\", 50);", RNOSTOP));			//  ShiftButton: Sound Reminder every 3 seconds
			MapKeyR(&MyThrottle, PSF, EXEC("StopAutoRepeat(hSoundFX);"));		//RELEASE					//  Cancel reminder soundfx
	
			MapKey(&MyThrottle, PSM, 0);																	//  ShiftButton for IOUMD
			
			MapKey(&MyThrottle, PSB, REXEC(hSoundFX, 3000, "fnSoundFX(\"boop\", 50);", RNOSTOP));			//  ShiftButton: Sound reminder every 3 seconds
			MapKeyR(&MyThrottle, PSB, EXEC("StopAutoRepeat(hSoundFX);"));		//RELEASE					//  Cancel reminder soundfx					
		}

	//	(Coolie Switch)		// Frame Shift Drive functions and Alternate YAW
	//	---------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, CSU, PULSE+Supercruise);
			MapKey(&MyThrottle, CSD, PULSE+HyperJump);
			MapKey(&MyThrottle, CSL, PULSE+SelectNextSystemInRoute);
			MapKey(&MyThrottle, CSR, PULSE+OrbitLines);
			}
		else {
			MapKeyIO(&MyThrottle, CSU,
				PitchUp,																					// I - Alt Pitch UP
				EXEC("tgWarpDrive(0);")																		// O - Toggle: Engage Super-cruise Engine
				);
			MapKeyIO(&MyThrottle, CSD, 
				PitchDown,																					// I - Alt Pitch Down
				EXEC("tgWarpDrive(1);")																		// O - Toggle: Initiate Hyper Jump
				);
			MapKeyIO(&MyThrottle, CSL, 
				YawLeft,																					// I - Alt YAW if no Rudder
				PULSE+SelectNextSystemInRoute																// O - Target Next System in jump route 
				);
			MapKeyIO(&MyThrottle, CSR,
				YawRight,																					// I - Alt YAW if no Rudder
				PULSE+OrbitLines																			// O - Toggle Orbit Lines ON/OFF 
				);
		}
		
	//	(Mike Switch)		// Usually used for Communications Control (not included in this release)
	//	-------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, MSU, EXEC("fnTextToSpeech(\"Not mapped\");"));	// <not mapped>
			MapKey(&MyThrottle, MSD, EXEC("fnTextToSpeech(\"Not mapped\");"));	// <not mapped>
			MapKey(&MyThrottle, MSL, EXEC("fnTextToSpeech(\"Not mapped\");"));	// <not mapped>
			MapKey(&MyThrottle, MSR, EXEC("fnTextToSpeech(\"Not mapped\");"));	// <not mapped>
			MapKey(&MyThrottle, MSP, EXEC("fnTextToSpeech(\"Not mapped\");"));	// <not mapped>
		}
		else {
			MapKey(&MyThrottle, MSU, EXEC("fnTextToSpeech(\"Not mapped\");"));	// <not mapped>
			MapKey(&MyThrottle, MSD, EXEC("fnTextToSpeech(\"Not mapped\");"));	// <not mapped>
			MapKey(&MyThrottle, MSL, EXEC("fnTextToSpeech(\"Not mapped\");"));	// <not mapped>
			MapKey(&MyThrottle, MSR, EXEC("fnTextToSpeech(\"Not mapped\");"));	// <not mapped>
//-			MapKey(&MyThrottle, MSP, EXEC("fnTextToSpeech(\"Not mapped\");"));	// <not mapped>
			MapKeyIO(&MyThrottle, MSP, 
				EXEC("fnPANIC();"),												// I - panic switch. Aborts script.
				EXEC("fnTextToSpeech(\"Use S3 + MSP to panic\");")				// O - 
				);
			}
		
		
	//	(Speed Brake)		// Reverse Throttle function modifiers
	//	-------------

		// Forward is a 2 position switch. Backward is a momentary action switch 

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, SPDF, PULSE+ReverseThrottle);
			MapKeyR(&MyThrottle, SPDF, PULSE+ReverseThrottle);												// RELEASE
			MapKey(&MyThrottle, SPDB, PULSE+EngineBoost);
		}
		else {
			MapKeyUMD(&MyThrottle, SPDF,
				0,																							// U - Align Switch only	- Deploy Speedbrake only (no Reverse)			
				EXEC("tgReverseThrust(1);"),																// M - Standard Reverse		- Deploy Speedbrake if Hardpoints deployed
				EXEC("tgReverseThrust(0);")																	// D - Reverse Only			- No Speedbrake
				);
	
			MapKeyR(&MyThrottle, SPDF, EXEC("tgReverseThrust(3);"));										// RELEASE - Turn off Reverse Throttle
			
			MapKey(&MyThrottle, SPDB, EXEC("tgBoost(0);"));													// Boost and SCO Engage 
		}
		
	//	(Boat Switch)		//
	//	-------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, BSF, 0); 
			MapKey(&MyThrottle, BSM, 0);
			MapKey(&MyThrottle, BSB, 0);
		}
		else {
			MapKeyUMD(&MyThrottle, BSF, 
				EXEC("tgWingBeacon(0);"),																	// U - NAV Beacon WING/OFF
//-				EXEC("tgTerrainFollow(ON);"),																// M - Terrain following ON
//-				EXEC("tgAutoPilot(ON);"),																	// M - Auto Pilot ON
				EXEC("fnSetOriginStation(1);"),																// M - Set Origin Satation Name
				EXEC("tgTxt2Speech();")																		// D - Toggle EnableVoice (TextToSpeech)
				);
			
//-			MapKeyR(&MyThrottle, BSF, EXEC("tgTerrainFollow(OFF);"));										// RELEASE				// Terrain following OFF
//-			MapKeyR(&MyThrottle, BSF, EXEC("tgAutoPilot(OFF);"));											// RELEASE				// Auto Pilot OFF
			
			MapKey(&MyThrottle, BSM, 0);																	// <not currently used>
			
			MapKeyUMD(&MyThrottle, BSB, 
				EXEC("tgReportCrimes(0);"),																	// U - Report crimes against me ON/OFF
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// M -
				EXEC("fnTextToSpeech(\"Not mapped\");")														// D -
				);
		}
	
	//	(China Hat)			// Subsystem Targetting
	//	-----------

		MapKey(&MyThrottle, CHF, PULSE+TargetNextSubsystem);
		MapKey(&MyThrottle, CHB, PULSE+TargetPrevSubsystem);
		
	////////////////////////////////////////////
	// ////////////////////////////////////// //
	//										  //
	// Map Throttle BASE buttons and switches //
	//										  //
	// ////////////////////////////////////// //
	////////////////////////////////////////////

	//	(AutoPilot Select)	// JoystickCurves Selector
	//	------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, APPAT, 0);
			MapKey(&MyThrottle, APAH,  0);
			MapKey(&MyThrottle, APALT, 0);
		}
		else {
			MapKeyIO(&MyThrottle, APPAT,
				EXEC("initCurves(MEDIUM, CurveInfo);"),														// I - Set Curves = MEDIUM
				EXEC("initCurves(MILD, CurveInfo);")														// O - Set Curves = MILD
				);
			
			MapKey(&MyThrottle, APAH,  EXEC("initCurves(OFF, CurveInfo);"));								// Set Curves = OFF
			
			MapKeyIO(&MyThrottle, APALT, 
				EXEC("initCurves(SLOWEST, CurveInfo);"),													// I - Set Curves = SLOWEST 
				EXEC("initCurves(SLOW, CurveInfo);")														// O - Set Curves = SLOW
				);
		}
		
	//	(Enhanced Attitude Control (EAC) Arm/Off)
	//	-----------------------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EACON, PULSE+SilentRunning);
			MapKey(&MyThrottle, EACOFF, PULSE+SilentRunning);
		}
		else {
			MapKeyIOUMD(&MyThrottle, EACON,
				0,																							// IU -	Use to fix mis-aligned switch 
				EXEC("tgSilentRunning(STROBE);"),															// OU -	Toggle AutoStrobe setting (refer ED_UserSettings.tmh) 
				EXEC("tgSilentRunning(STROBE);"),															// IM - Strobe Silent running every 2 seconds
				EXEC("tgSilentRunning(ON);"),																// OM - Engage Silent Running
				0,																							// ID - 
				0																							// OD - 
			);
			
			MapKey(&MyThrottle, EACOFF, EXEC("tgSilentRunning(OFF);"));
		}
		
	//	(Radar Altimeter)
	//	-----------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, RDRNRM, PULSE+CargoScoop);
			MapKey(&MyThrottle, RDRDIS, PULSE+CargoScoop);
		}
		else {
			MapKeyIOUMD(&MyThrottle, RDRNRM,
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// IU - 
				0,																							// OU - (PSF+) Use to fix mis-aligned switch 
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// IM -
				EXEC("tgCargoScoop(DEPLOY);"),																// OM - Deploy Cargo Scoop
				PULSE+EjectCargo,																			// ID - (S3+PSB+) About as safe as I can make it!
				EXEC("fnTextToSpeech(\"Not mapped\");")														// OD -
			);
		
			MapKey(&MyThrottle, RDRDIS, EXEC("tgCargoScoop(RETRACT);"));
		}

	//	(Landing Gear Horn)
	//	-------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, LDGH, 0); 
		}
		else {
			MapKeyIO(&MyThrottle, LDGH, 
				EXEC("fnClearChatBox(1);"),																	// Clear all chat box windows
				EXEC("fnClearChatBox(0);")																	// Clear currently selected chat box window
				);
		}

	//	(Autopilot Engage)
	//	------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, APENG, 0); 
		}
		else {
			MapKeyIOUMD(&MyThrottle, APENG,
				EXEC("fnHangarServices(4);"),																// IU - Toggle AutoDisembark
				EXEC("fnHangarServices(2);"),																// OU - Toggle AutoHangar
				EXEC("fnHangarServices(1);"),																// IM - Refuel, Rearm, Repair, Hangar Services
				EXEC("fnRequestDock();"),																	// OM - Request Docking
				0,																							// ID -
				EXEC("fnHangarServices(3);")																// OD - Refuel, Rearm, Repair, Disembark
				);
		}

	//	(Flaps)
	//	-------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, FLAPU, PULSE+GalMap);
			MapKeyR(&MyThrottle, FLAPU,  PULSE+GalMap);														// RELEASE
			
			MapKey(&MyThrottle, FLAPM, 0);
			
			MapKey(&MyThrottle, FLAPD, PULSE+SystemMap);
			MapKeyR(&MyThrottle, FLAPD,  PULSE+SystemMap);													// RELEASE			
			}
		else {
			MapKeyUMD(&MyThrottle, FLAPU,
				EXEC("fnVoiceVolume(INCREASE);"),															// U - Increase TextToSpeech volume
				EXEC("tgGALMap(ON);"),																		// M - Galaxy Map - ON
				EXEC("fnLEDBrightness(INCREASE);")															// D - Increase LED Brightness 
				);
				
			MapKeyRUMD(&MyThrottle, FLAPU,																	// RELEASE
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// RU -
				EXEC("tgGALMap(OFF);"),																		// RM - Galaxy Map - OFF
				EXEC("fnTextToSpeech(\"Not mapped\");")														// RD -
				);
				
			MapKey(&MyThrottle, FLAPM, 0);																	// No point announcing this is not used 
				
			MapKeyUMD(&MyThrottle, FLAPD,
				EXEC("fnVoiceVolume(DECREASE);"),															// U - Decrease TextToSpeech volume
				EXEC("tgSYSMap(ON);"),																		// M - System Map - ON
				PULSE+LED(&MyThrottle, LED_INTENSITY, 0)													// D - Turn Throttle Base LEDs off 
				);
				
			MapKeyRUMD(&MyThrottle, FLAPD,																	// RELEASE
				EXEC("fnTextToSpeech(\"Not mapped\");"),													// RU -
				EXEC("tgSYSMap(OFF);"),																		// RM - System Map - OFF
				EXEC("fnLEDBrightness();")																	// RD - Turn Throttle Base LEDs on
				);
		}
		
	//	(Auxiliary Power Unit)
	//	----------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, APUON, 0);
			MapKey(&MyThrottle, APUOFF, 0);
		}
		else {
			MapKeyIO(&MyThrottle, APUON,																	// "APU Start"	= Deploy SRV/Fighter
				EXEC("fnDeployFighter(DEPLOY);"),															// I -
				EXEC("fnDeploySRV(DEPLOY);")																// O -
			);
			
			MapKeyIO(&MyThrottle, APUOFF, 																	// "APU OFF"	= Recover SRV/Fighter
				EXEC("fnDeployFighter(RECOVER);"),															// I -
				EXEC("fnDeploySRV(RECOVER);")																// O - 
			);
		}

	//	(Engine Operate - Right)
	//	------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EORIGN, 0);
		}
		else {
			MapKey(&MyThrottle, EORIGN, EXEC("fnDRShip();"));												// Momentary Contact (UP) - From SRV - Recall/Dismiss Ship
		}
		
		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EORMOTOR, PULSE+HideShipGUI);												// (DOWN) Toggle Heads up display GUI 
		}
		else {		
			MapKeyIO(&MyThrottle, EORMOTOR, 
						0,																					// I - Use to fix misalligned switch
						PULSE+HideShipGUI																	// O - Toggle: Ship GUI OFF
						);
		}		
		MapKeyR(&MyThrottle, EORMOTOR, PULSE+HideShipGUI);	// RELEASE										// Toggle: Ship GUI ON

		MapKey(&MyThrottle, EORNORM, 0);																	// Not Mapped

	//	(Engine Operate - Left)
	//	-----------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EOLIGN, 0);
		}
		else {
			MapKeyUMD(&MyThrottle, EOLIGN,																	// Menu Log to ...
				 EXEC("fnModeSwitch(0);"),																	// U - OPEN Mode
				 EXEC("fnModeSwitch(1);"),																	// M - PRIVATE Mode
				 EXEC("fnModeSwitch(2);")																	// D - SOLO Mode
				 );
		}
				 
		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EOLMOTOR, CHAIN(PULSE+EngineColour, D(), PULSE+WeaponColour));				// Toggle Engine and Weapon Colours
		}
		else {
			MapKey(&MyThrottle, EOLMOTOR, PULSE+m_ChangeColours);											// Toggle Engine and Weapon Colours				
		}

		MapKey(&MyThrottle, EOLNORM, 0);																	// <not currently used>

	//	(Engine Fuel Flow - Right)
	//	--------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EFRNORM, 0);
		}
		else {
			MapKeyUMD(&MyThrottle, EFRNORM,
				EXEC("fnPrintState();"),																	// U -	Print Status Page
				EXEC("fnSetLEDs();"),																		// M -	Reset Status LEDs manually
				EXEC("stfnMyStates(SAVE);")																	// D -	Save MyStates to MyWarthogStatusFile.json
				);																							//		This is usefull when adding or removing vars to json file 
		}
				
		MapKey(&MyThrottle, EFROVER, 0);																	// <not currently used>

	//	(Engine Fuel Flow - Left)
	//	-------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EFLNORM, PULSE+Screenshot);													// F10 - Take a screenshot
		}
		else {
			MapKeyUMD(&MyThrottle, EFLNORM,	
				EXEC("fnDEBUG(0);"),																		// U - Test function switch. Runs fnDEBUG() to test code and calls etc.
				PULSE+Screenshot,																			// M - Screen Capture
				EXEC("fnTextToSpeech(\"Not mapped\");")														// D -
				);	
		}
				
		MapKey(&MyThrottle, EFLOVER, 0);																	// <not currently used>

	//	(Engine Idle - Left)
	//	--------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, IDLELON, 0);
			MapKey(&MyThrottle, IDLELOFF, 0);
		}
		else {
			MapKey(&MyThrottle, IDLELON, EXEC("fnIdleLock(1);"));											// Enter Hangar and Station Services if Ship else Handbrake if SRV
			MapKey(&MyThrottle, IDLELOFF, EXEC("fnIdleLock(0);"));											// Exit Hangar, Lift off if in Ship, else Handbrake off if in SRV
		}

	//	(Engine Idle - Right)																				// NOTE: You can use these if Throttles are decoupled
	//	---------------------
		
		MapKey(&MyThrottle, IDLERON, 0);																	// <not currently used>
		MapKey(&MyThrottle, IDLEROFF, 0);																	// <not currently used>

		// MapKeys FINISHED - Print current mode to console 
		printf("\x0a\++	HOTAS Mode:		LIVE\x0a");
		
	}	// end of LiveKeyMap
	

	// =============================================================================================================================================
	// =============================================================================================================================================


	// --------------------------- //
	//  KeyMaps for Training Mode  //
	// --------------------------- //

	// FUNCTION:	This MapKey set is called at startup if game is not running and user setting 'TrainingMode' is set to ENABLED in ED_UserSettings.tmh 
	//				Also called from stfnProcessFlags() when we detect Game has halted

	int TrainingKeyMap() {

	// //////////////////////////////////////// //
	// //////////////////////////////////////// //
	//											//
	// Map Joystick triggers, switches and hats //
	//											//
	// //////////////////////////////////////// //
	// //////////////////////////////////////// //

	//	(Gun Trigger - Primary Fire)
	//	----------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, TG1, EXEC("fnVPOutput(\"Primary Fire\", 0, 1);"));
		}
		else {
			MapKeyUMD(&MyJoystick, TG1,		// (Gun Trigger - Stage 1)
				EXEC("fnVPOutput(\"Toggle Primary Trigger Mode\", 0, 1);"),
				EXEC("fnVPOutput(\"Primary Fire\", 0, 1);"),
				EXEC("fnVPOutput(\"Advanced Primary trigger mode\", 0, 1);")
				);
		}
							
		MapKey(&MyJoystick, TG2, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));	// (Gun Trigger - Stage 2)

	//		(Master Mode Control Button)
	//		----------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, S1, EXEC("fnVPOutput(\"Toggle Hardpoints\", 0, 1);"));
		}
		else {		
			MapKeyUMD(&MyJoystick, S1, 
				EXEC("fnVPOutput(\"Toggle HUD Mode\", 0, 1);"),
				EXEC("fnVPOutput(\"Toggle Hardpoints\", 0, 1);"),
				EXEC("fnVPOutput(\"Toggle Auto hud user setting\", 0, 1);")
				);
		}
	
	//		(Weapons Release Button - Secondary Fire)
	//		-----------------------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, S2, EXEC("fnVPOutput(\"Secondary Fire\", 0, 1);"));
		}
		else {		
			MapKeyUMD(&MyJoystick, S2,
				EXEC("fnVPOutput(\"Toggle Secondary Trigger Mode\", 0, 1);"),
				EXEC("fnVPOutput(\"Secondary Fire\", 0, 1);"),
				EXEC("fnVPOutput(\"Advanced Secondary trigger mode\", 0, 1);")
				);
		}
				
	// 		(Nosewheel Steering Button)
	//		---------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, S3, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
		}
		else {	
			MapKey(&MyJoystick, S3, EXEC("fnVPOutput(\"I O layer button\", 0, 1);"));
		}

	//		(Joystick Pinky Lever Switch)
	//		-----------------------------

		MapKeyUMD(&MyJoystick, S4,
			EXEC("fnVPOutput(\"Toggle Flight Assist with joystick mouse emulation\", 0, 1);"),
			EXEC("fnVPOutput(\"Toggle Flight Assist\", 0, 1);"),
			EXEC("fnVPOutput(\"Toggle Joystick X Axis between Roll and Yaw\", 0, 1);")
			);

	//		China Hat (Trim Switch)
	//		-----------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, H1U, EXEC("fnVPOutput(\"Select next fire group\", 0, 1);"));
			MapKey(&MyJoystick, H1D, EXEC("fnVPOutput(\"Select previous fire group\", 0, 1);"));
			MapKey(&MyJoystick, H1L, EXEC("fnVPOutput(\"Toggle landing gear\", 0, 1);"));
			MapKey(&MyJoystick, H1R, EXEC("fnVPOutput(\"Toggle ship lights\", 0, 1);"));
		}
		else {		
			MapKeyUMD(&MyJoystick, H1U,
				EXEC("fnVPOutput(\"Toggle F S S Mode\", 0, 1);"),
				EXEC("fnVPOutput(\"Select next fire group\", 0, 1);"),
				EXEC("fnVPOutput(\"Exit D S S Mode\", 0, 1);")
				);
	
			MapKey(&MyJoystick, H1D, EXEC("fnVPOutput(\"Select previous fire group\", 0, 1);"));
			
			MapKeyUMD(&MyJoystick, H1L,
				EXEC("fnVPOutput(\"Toggle Auto gear up user setting\", 0, 1);"),
				EXEC("fnVPOutput(\"Hold for half second to toggle landing gear\", 0, 1);"),
				EXEC("fnVPOutput(\"Toggle Auto gear down user setting\", 0, 1);")
				);
	
			
			MapKeyUMD(&MyJoystick, H1R,
				EXEC("fnVPOutput(\"Toggle Night Vision\", 0, 1);"),
				EXEC("fnVPOutput(\"Hold for half second to toggle ship lights\", 0, 1);"),
				EXEC("fnVPOutput(\"Toggle auto landing lights user setting\", 0, 1);")
				);
		}
	
	//		(Target Management Switch)			// Target Designator
	//		--------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, H2U, EXEC("fnVPOutput(\"Select target ahead\", 0, 1);"));
			MapKey(&MyJoystick, H2D, EXEC("fnVPOutput(\"Target highest threat\", 0, 1);"));
			MapKey(&MyJoystick, H2L, EXEC("fnVPOutput(\"Target next ship\", 0, 1);"));
			MapKey(&MyJoystick, H2R, EXEC("fnVPOutput(\"Target next hostile\", 0, 1);"));
		}
		else {		
			MapKeyUMD(&MyJoystick, H2U,
				EXEC("fnVPOutput(\"Toggle Front-Back view of planet in DSS Mode\", 0, 1);"),
				EXEC("fnVPOutput(\"Select target ahead\", 0, 1);"),
				EXEC("fnVPOutput(\"Select target ahead\", 0, 1);")
				);
				
			MapKeyUMD(&MyJoystick, H2D,
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),
				EXEC("fnVPOutput(\"Target highest threat\", 0, 1);"),
				EXEC("fnVPOutput(\"Target wingmans target\", 0, 1);")
				);
				
			MapKeyUMD(&MyJoystick, H2L,
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),
				EXEC("fnVPOutput(\"Target next ship\", 0, 1);"),
				EXEC("fnVPOutput(\"Select next wingman\", 0, 1);")
				);
				
			MapKeyUMD(&MyJoystick, H2R,
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),
				EXEC("fnVPOutput(\"Target next hostile\", 0, 1);"),
				EXEC("fnVPOutput(\"Select wingmans NAV target\", 0, 1);")
				);
		}
	
	//	(Data Management Switch)				// Power (PIP) Management
	//	------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, H3U, EXEC("fnVPOutput(\"PIP Manager, Engine Focussed\", 0, 1);"));
			MapKey(&MyJoystick, H3D, EXEC("fnVPOutput(\"PIP Manager, Balance PIPs\", 0, 1);"));
			MapKey(&MyJoystick, H3L, EXEC("fnVPOutput(\"PIP Manager, System Focussed\", 0, 1);"));
			MapKey(&MyJoystick, H3R, EXEC("fnVPOutput(\"PIP Manager, Weapon Focussed\", 0, 1);"));
		}
		else {
			MapKeyUMD(&MyJoystick, H3U, 
				EXEC("fnVPOutput(\"Fighter, Attack\", 0, 1);"),
				EXEC("fnVPOutput(\"PIP Manager, Engine Focussed\", 0, 1);"),
				EXEC("fnVPOutput(\"Fighter, Attack\", 0, 1);")			
			);
			
			MapKeyUMD(&MyJoystick, H3D, 
				EXEC("fnVPOutput(\"Fighter, Follow no fire\", 0, 1);"),
				EXEC("fnVPOutput(\"PIP Manager, Balance PIPs\", 0, 1);"),
				EXEC("fnVPOutput(\"Fighter, hold\", 0, 1);")
			);
			
			MapKeyUMD(&MyJoystick, H3L, 
				EXEC("fnVPOutput(\"Fighter, Defend\", 0, 1);"),
				EXEC("fnVPOutput(\"PIP Manager, System Focussed\", 0, 1);"),
				EXEC("fnVPOutput(\"Fighter, Follow\", 0, 1);")
			);
			
			MapKeyUMD(&MyJoystick, H3R, 
				EXEC("fnVPOutput(\"Fighter, Aggressive\", 0, 1);"),
				EXEC("fnVPOutput(\"PIP Manager, Weapon Focussed\", 0, 1);"),
				EXEC("fnVPOutput(\"Fighter, Aggressive\", 0, 1);")
			);
		}
		
	//	(Countermeasures Management Switch)		// Countermeasures and camera/FSS Zoom
	//	-----------------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyJoystick, H4U, EXEC("fnVPOutput(\"Shield cell bank\", 0, 1);"));
			MapKey(&MyJoystick, H4D, EXEC("fnVPOutput(\"Fire a heat sink\", 0, 1);"));
			MapKey(&MyJoystick, H4L, EXEC("fnVPOutput(\"Hold to charge ECM, release to fire\", 0, 1);"));
			MapKey(&MyJoystick, H4R, EXEC("fnVPOutput(\"Fire chaff\", 0, 1);"));
			MapKey(&MyJoystick, H4P, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));			
		}
		else {
			MapKeyUMD(&MyJoystick, H4U,
				EXEC("fnVPOutput(\"Double Shield Cell plus one heat sink\", 0, 1);"),
				EXEC("fnVPOutput(\"Short press for single shield cell bank, hold for half second to include a heatsink\", 0, 1);"),
				EXEC("fnVPOutput(\"Camera zoom in\", 0, 1);")
				);
				
			MapKeyUMD(&MyJoystick, H4D,
				EXEC("fnVPOutput(\"Toggle Auto heat sink user setting\", 0, 1);"),
				EXEC("fnVPOutput(\"Fire a heat sink\", 0, 1);"),
				EXEC("fnVPOutput(\"Camera zoom out\", 0, 1);")
				);
	
			MapKeyUMD(&MyJoystick, H4L,
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),
				EXEC("fnVPOutput(\"Hold to charge ECM, release to fire\", 0, 1);"),
				EXEC("fnVPOutput(\"Camera blur out\", 0, 1);")
				);
	
			MapKeyUMD(&MyJoystick, H4R,
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),
				EXEC("fnVPOutput(\"Fire chaff\", 0, 1);"),
				EXEC("fnVPOutput(\"Camera blur in\", 0, 1);")
				);
				
			MapKeyUMD(&MyJoystick, H4P,
				EXEC("fnVPOutput(\"Reset PIP Mode\", 0, 1);"),
				EXEC("fnVPOutput(\"Increment PIP Mode\", 0, 1);"),
				EXEC("fnVPOutput(\"Decrement PIP Mode\", 0, 1);")
				);
		}
	
	// //////////////////////////////////// //
	// //////////////////////////////////// //
	//										//
	// Map Throttle LEVER switches and hats //
	//										//
	// //////////////////////////////////// //
	// //////////////////////////////////// //

	//		(Slew Control Button)		// Miscellaneous
	//		---------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, SC, EXEC("fnVPOutput(\"Re-centre Heeadlook\", 0, 1);"));
		}
		else {
			MapKeyUMD(&MyThrottle, SC,
				EXEC("fnVPOutput(\"Show connection status\", 0, 1);"),
				EXEC("fnVPOutput(\"Re-centre Headlook\", 0, 1);"),
				EXEC("fnVPOutput(\"Show Frame rate in FPS\", 0, 1);")
				);
		}
	
	// 		(Left Throttle Button)	// Headlook On/Off / External Camera
	//		----------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, LTB, EXEC("fnVPOutput(\"Toggle Headlook\", 0, 1);"));
		}
		else {
			MapKeyUMD(&MyThrottle, LTB,
				EXEC("fnVPOutput(\"Toggle External Camera\", 0, 1);"),
				EXEC("fnVPOutput(\"Toggle Headlook\", 0, 1);"),
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);")
				);
		}
	
	//		(Pinky Switch)		// Modifier Switch
	//		--------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, PSF, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, PSM, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, PSB, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
		}
		else {
			MapKey(&MyThrottle, PSF, EXEC("fnVPOutput(\"UMD Layer Forward and sound reminder every 3 seconds\", 0, 1);"));
			MapKeyR(&MyThrottle, PSF, EXEC("fnVPOutput(\"UMD Layer Middle and cancel reminder sound\", 0, 1);"));
			
//-			MapKey(&MyThrottle, PSM, EXEC("fnVPOutput(\"U M D Layer Middle\", 0, 1);"));
			
			MapKey(&MyThrottle, PSB, EXEC("fnVPOutput(\"UMD Layer Back and sound reminder every 3 seconds\", 0, 1);"));
			MapKeyR(&MyThrottle, PSB, EXEC("fnVPOutput(\"UMD Layer Middle and cancel reminder sound\", 0, 1);"));
		}
	
	//		(Coolie Switch)		// Frame Shift Drive functions
	//		---------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, CSU, EXEC("fnVPOutput(\"Toggle Supercruise\", 0, 1);"));
			MapKey(&MyThrottle, CSD, EXEC("fnVPOutput(\"Toggle System jump\", 0, 1);"));
			MapKey(&MyThrottle, CSL, EXEC("fnVPOutput(\"Select next system in route\", 0, 1);"));
			MapKey(&MyThrottle, CSR, EXEC("fnVPOutput(\"Toggle orbit lines\", 0, 1);"));
		}
		else {
			MapKeyIO(&MyThrottle, CSU, 
				EXEC("fnVPOutput(\"Pitch up\", 0, 1);"),				
				EXEC("fnVPOutput(\"Toggle Supercruise\", 0, 1);")
				);
			MapKeyIO(&MyThrottle, CSD, 
				EXEC("fnVPOutput(\"Pitch down\", 0, 1);"),				
				EXEC("fnVPOutput(\"Toggle System jump\", 0, 1);")
				);
			MapKeyIO(&MyThrottle, CSL, 
				EXEC("fnVPOutput(\"Yaw Left\", 0, 1);"),
				EXEC("fnVPOutput(\"Select next system in route\", 0, 1);")
				);
			MapKeyIO(&MyThrottle, CSR, 
				EXEC("fnVPOutput(\"Yaw Right\", 0, 1);"),			
				EXEC("fnVPOutput(\"Toggle orbit lines\", 0, 1);")
				);		
		}


	//		(Mike Switch)		// Communications Controller functions
	//		-------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, MSU, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, MSD, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, MSL, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, MSR, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));		
			MapKey(&MyThrottle, MSP, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
		}
		else {
			MapKey(&MyThrottle, MSU, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, MSD, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, MSL, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, MSR, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));		
//-			MapKey(&MyThrottle, MSP, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKeyIO(&MyThrottle, MSP, 
				EXEC("fnPANIC();"),									// I - panic switch 
				EXEC("fnVPOutput(\"Use S3 + MSP to panic\");")		// O - 
				);

		}
		
	
	//		(Speed Brake)		// Reverse Throttle function modifiers
	//		-------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, SPDF, EXEC("fnVPOutput(\"Reverse thrusters\", 0, 1);"));
			MapKeyR(&MyThrottle, SPDF, PULSE+ReverseThrottle);	// RELEASE
		}
		else {
			MapKeyUMD(&MyThrottle, SPDF,
				EXEC("fnVPOutput(\"Reverse thrusters, no speed brake\", 0, 1);"),
				EXEC("fnVPOutput(\"Reverse thrusters with speed brake\", 0, 1);"),
				EXEC("fnVPOutput(\"Fix Switch position alignment to match in game for reverse thrust\", 0, 1);")
				);
		}
	
		MapKeyR(&MyThrottle, SPDF, EXEC("fnVPOutput(\"Forward Thrusters\", 0, 1);"));							// RELEASE

		MapKey(&MyThrottle, SPDB, EXEC("fnVPOutput(\"Engine Boost\", 0, 1);"));

	
	//		(Boat Switch)		//
	//		-------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, BSF, EXEC("fnVPOutput(\"Not mapped\", 0, 1);")); 
			MapKey(&MyThrottle, BSB, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
		}
		else {
			MapKeyUMD(&MyThrottle, BSF, 
				EXEC("fnVPOutput(\"Toggle Wing Beacon between wing and off\", 0, 1);"),							// U -
//-				EXEC("fnVPOutput(\"Terrain following ON\", 0, 1);"),											// M -
//-				EXEC("fnVPOutput(\"Auto pilot ON\", 0, 1);"),													// M -
				EXEC("fnVPOutput(\"Set Origin Station\", 0, 1);"),												// M -
				EXEC("fnVPOutput(\"Toggle Text to speech function off and on\", 0, 1);")						// D -
				);
//-			MapKeyR(&MyThrottle, BSF, EXEC("fnVPOutput(\"Terrain following OFF\", 0, 1);"));					// RETURN 
//-			MapKeyR(&MyThrottle, BSF, EXEC("fnVPOutput(\"Auto Pilot OFF\", 0, 1);"));							// RETURN 
						
			MapKeyUMD(&MyThrottle, BSB, 
				EXEC("fnVPOutput(\"Toggle report crimes against me on and off\", 0, 1);"),						// U -
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),														// M -
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);")														// D -
				);
		}
	
	//		(China Hat)			// Subsystem Targetting
	//		-----------

		MapKey(&MyThrottle, CHF, EXEC("fnVPOutput(\"Target Next Subsystem\", 0, 1);"));
		MapKey(&MyThrottle, CHB, EXEC("fnVPOutput(\"Target Previous Subsystem\", 0, 1);"));
		

	////////////////////////////////////////////
	// ////////////////////////////////////// //
	//										  //
	// Map Throttle BASE buttons and switches //
	//										  //
	// ////////////////////////////////////// //
	////////////////////////////////////////////

	//		(AutoPilot Select)	// JoystickCurves Selector
	//		------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, APPAT, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, APAH,  EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, APALT, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
		}
		else {
			MapKeyIO(&MyThrottle, APPAT, 
			EXEC("fnVPOutput(\"Set axis curves medium\", 0, 1);"),
			EXEC("fnVPOutput(\"Set axis curves mild\", 0, 1);")
			);
			
			MapKey(&MyThrottle, APAH,  EXEC("fnVPOutput(\"Set axis curves off\", 0, 1);"));
			
			MapKeyIO(&MyThrottle, APALT, 
				EXEC("fnVPOutput(\"Set axis curves slowest\", 0, 1);"),
				EXEC("fnVPOutput(\"Set axis curves slow\", 0, 1);")
				);
		}
	
	//		(Enhanced Attitude Control (EAC) Arm/Off)
	//		-----------------------------------------
		
		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EACON, EXEC("fnVPOutput(\"Engage Silent running\", 0, 1);"));
		}
		else {
			MapKeyIOUMD(&MyThrottle, EACON,
				EXEC("fnVPOutput(\"Fix mis aligned switch\", 0, 1);"),
				EXEC("fnVPOutput(\"Toggle auto strobe user setting\", 0, 1);"),
				EXEC("fnVPOutput(\"Engage Silent running strobe function\", 0, 1);"),
				EXEC("fnVPOutput(\"Engage Silent running\", 0, 1);"),
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);")
			);
		}
				
		MapKey(&MyThrottle, EACOFF, EXEC("fnVPOutput(\"Disengage silent running\", 0, 1);"));
		
	//		(Radar Altimeter)
	//		-----------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, RDRNRM, EXEC("fnVPOutput(\"Deploy cargo scoop\", 0, 1);"));
		}
		else {
			MapKeyIOUMD(&MyThrottle, RDRNRM, 
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),
				EXEC("fnVPOutput(\"Fix mis aligned switch\", 0, 1);"),
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),			
				EXEC("fnVPOutput(\"Deploy cargo scoop\", 0, 1);"),
				EXEC("fnVPOutput(\"Jettison Cargo\", 0, 1);"),
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);")
			);
		}
			
		MapKey(&MyThrottle, RDRDIS, EXEC("fnVPOutput(\"Retract cargo scoop\", 0, 1);"));

	//		(Landing Gear Horn)
	//		-------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, LDGH, EXEC("fnVPOutput(\"Not mapped\", 0, 1);")); 
		}
		else {
			MapKeyIO(&MyThrottle, LDGH, 
				EXEC("fnVPOutput(\"Clear all chat boxes\", 0, 1);"),
				EXEC("fnVPOutput(\"Clear currently selected chat box\", 0, 1);")
				);
		}
	
	//		(Autopilot Engage)
	//		------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, APENG, EXEC("fnVPOutput(\"Not mapped\", 0, 1);")); 
		}
		else {
			MapKeyIOUMD(&MyThrottle, APENG,
				EXEC("fnVPOutput(\"Toggle auto disembark setting\", 0, 1);"),										// IU - 
				EXEC("fnVPOutput(\"Toggle auto hangar user setting\", 0, 1);"),										// OU -
				EXEC("fnVPOutput(\"Enter Hangar services\", 0, 1);"),												// IM - 
				EXEC("fnVPOutput(\"Request docking permission\", 0, 1);"),											// OM -
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),															// ID - 
				EXEC("fnVPOutput(\"Disembark from ship\", 0, 1);")													// OD - 
				);
		}
	
	//		(Flaps)
	//		-------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, FLAPU, EXEC("fnVPOutput(\"Open Galaxy Map\", 0, 1);"));
			MapKeyR(&MyThrottle, FLAPU, EXEC("fnVPOutput(\"Close Galaxy Map\", 0, 1);"));							// RELEASE
			MapKey(&MyThrottle, FLAPD, EXEC("fnVPOutput(\"Open System Map\", 0, 1);"));
			MapKeyR(&MyThrottle, FLAPD, EXEC("fnVPOutput(\"Close System Map\", 0, 1);"));							// RELEASE			
			}
		else {
			MapKeyUMD(&MyThrottle, FLAPU,
				EXEC("fnVPOutput(\"Increase voice feedback volume\", 0, 1);"),
				EXEC("fnVPOutput(\"Open Galaxy Map\", 0, 1);"),
				EXEC("fnVPOutput(\"Increase LED brightness\", 0, 1);")
				);
	
			MapKeyRUMD(&MyThrottle, FLAPU,		// RELEASE
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),
				EXEC("fnVPOutput(\"Close Galaxy Map\", 0, 1);"),
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);")
				);
	
	
			MapKeyUMD(&MyThrottle, FLAPD,
				EXEC("fnVPOutput(\"Decrease voice feedback volume\", 0, 1);"),
				EXEC("fnVPOutput(\"Open System Map\", 0, 1);"),
				EXEC("fnVPOutput(\"Turn Throttle LEDs off\", 0, 1);")
				);
	
			MapKeyRUMD(&MyThrottle, FLAPD,		// RELEASE
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);"),
				EXEC("fnVPOutput(\"Close System Map\", 0, 1);"),
				EXEC("fnVPOutput(\"Turn Throttle LEDs on\", 0, 1);")
				);
		}
	

	//		(Auxiliary Power Unit)
	//		----------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, APUON, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, APUOFF, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
		}
		else {
			MapKeyIO(&MyThrottle, APUON, 
				EXEC("fnVPOutput(\"Deploy Fighter\", 0, 1);"),
				EXEC("fnVPOutput(\"Deploy SRV\", 0, 1);")
			);

			MapKeyIO(&MyThrottle, APUOFF, 
				EXEC("fnVPOutput(\"Recover Fighter\", 0, 1);"),
				EXEC("fnVPOutput(\"Recover SRV\", 0, 1);")
			);
		}
	
	//		(Engine Operate - Right)
	//		------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EORIGN, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
		}
		else {
			MapKey(&MyThrottle, EORIGN, EXEC("fnVPOutput(\"Dismiss or recall ship\", 0, 1);"));
		}

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EORNORM, EXEC("fnVPOutput(\"Toggle Ship G U I off\", 0, 1);"));
		}
		else {
			MapKeyIO(&MyThrottle, EORMOTOR, 
				EXEC("fnVPOutput(\"Align Ship G U I switch\", 0, 1);"),
				EXEC("fnVPOutput(\"Toggle Ship G U I off\", 0, 1);")
				);
		}
				
		MapKeyR(&MyThrottle, EORMOTOR, EXEC("fnVPOutput(\"Toggle ship G U I on\", 0, 1);"));						// RELEASE

		
	//		(Engine Operate - Left)
	//		-----------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EOLIGN, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
		}
		else {
			MapKeyUMD(&MyThrottle, EOLIGN,
				 EXEC("fnVPOutput(\"Switch Game mode to Open\", 0, 1);"),
				 EXEC("fnVPOutput(\"Switch Game mode to Private Group\", 0, 1);"),
				 EXEC("fnVPOutput(\"Switch Game mode to solo\", 0, 1);")
				 );
		}
				 
		MapKey(&MyThrottle, EOLMOTOR, EXEC("fnVPOutput(\"Toggle Engine and Weapon colours\", 0, 1);"));		

	//		(Engine Fuel Flow - Right)
	//		--------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EFRNORM, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
		}
		else {
			MapKeyUMD(&MyThrottle, EFRNORM,
				EXEC("fnVPOutput(\"Print status page to Con-sole\", 0, 1);"),
				EXEC("fnVPOutput(\"Reset status LEDs\", 0, 1);"),
		//		EXEC("fnVPOutput(\"Save my status file\", 0, 1);")
				EXEC("stfnMyStates(SAVE);")									// use this when manually updating states to file and don't want to run/exit the game
				);
		}
				
		MapKey(&MyThrottle, EFROVER, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));

	//		(Engine Fuel Flow - Left)
	//		-------------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, EFLNORM, EXEC("fnVPOutput(\"Take screen shot\", 0, 1);"));
		}
		else {
			MapKeyUMD(&MyThrottle, EFLNORM,
				EXEC("fnVPOutput(\"Run debug function\", 0, 1);"),
//-				EXEC("fnDEBUG(0);"),
				EXEC("fnVPOutput(\"Take screen shot\", 0, 1);"),
				EXEC("fnVPOutput(\"Not mapped\", 0, 1);")
				);	
		}

	//		(Engine Idle - Left)
	//		--------------------

		if (MapKeyProfile == BASIC) {
			MapKey(&MyThrottle, IDLELON, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
			MapKey(&MyThrottle, IDLELOFF, EXEC("fnVPOutput(\"Not mapped\", 0, 1);"));
		}
		else {
			MapKey(&MyThrottle, IDLELON, EXEC("fnVPOutput(\"If in ship, Enter hangar services. If in SRV, handbrake\", 0, 1);"));
			MapKey(&MyThrottle, IDLELOFF, EXEC("fnVPOutput(\"If in ship, Exit Hangar services and lift off. If in SRV release handbrake\", 0, 1);"));
		}
	
	//		(Engine Idle - Right)
	//		---------------------
		
		MapKey(&MyThrottle, IDLERON, 0);				// <not used>
		MapKey(&MyThrottle, IDLEROFF, 0);				// <not used>

		// MapKeys FINISHED - Print current mode to console 
		printf("\x0a\++	HOTAS Mode:		TRAINING - Press a button or flick a switch to see or hear what it does.\x0a");

	}	// end of TrainingKeyMap

