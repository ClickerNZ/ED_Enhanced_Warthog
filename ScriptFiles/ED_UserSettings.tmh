
	//----------------------------------------------------------------------//
	//	CMDR Clicker's Elite Dangerous Thrustmaster Warthog + TFRP Script	//
	//----------------------------------------------------------------------//

	// This file: ED_UserSettings.tmh ... supports Elite Dangerous (Trailblazers)

	// Refer Change Log.txt in parent folder

	// LEGEND: 
	// ========================================================================
	// fnName()								refer to ED_Functions file
	// initName()							refer to ED_Initialise file
	// stfnName()							refer to ED_StateTracker file
	// tgName()								refer to ED_Toggles file
	// mName								refer to ED_Macros file
	// MapKey statements					refer to ED_MapKeyAssignment file
	// Global State and Boolean Defines		refer to ED_ScriptDefines file
	// Global Game Key Bind Defines			refer to ED_GameBindings file 
	// Global Script Variables				refer to ED_GlobalVars file
	// User Config Settings					refer to ED_UserSettings file
	// ========================================================================

	// START

	//-----------------------------//									
	// CRITICAL File Path Settings //		REFER TO DEDICATED SECTIONS BELOW FOR EXPLANATIONS
	//-----------------------------//

	// Refer 'status.json' section
	alias	StatusFile			= "d:\\Users\\den\\Saved Games\\Frontier Developments\\Elite Dangerous\\status.json";			// This is critical and must be set correctly
	alias	MaxStatusFile		= "d:\\Users\\den\\Saved Games\\Frontier Developments\\Elite Dangerous\\NewMaxJson.json";		// You can set the path to anywhere you like. I prefer keeping this in same folder as status.json 

	// Refer 'MyStatusFile' section																								// If you unzipped the package to 'c:\Thrustmaster\ED_TargetScript_Warthog\' as suggested...
	alias	MyStatusFile		= "C:\\Thrustmaster\\ED_TargetScript_Warthog\\SupportFiles\\Output\\MyWarthogStatusFile.json";	// ... this won't need changing

	// Refer 'MyJournalData' section
	alias	MyJournalData		= "C:\\Thrustmaster\\ED_TargetScript_Warthog\\SupportFiles\\Output\\MyJournalData.json";		// ... this won't need changing

	// Refer 'Text To Speech' section
	alias	TTSQueue 			= "C:\\Thrustmaster\\ED_TargetScript_Warthog\\SupportFiles\\Output\\TTSQueue\\";				// ... this won't need changing

	// Refer 'WAV Sound Player' section 
	alias	SoundPath			= "C:\\Thrustmaster\\ED_TargetScript_Warthog\\SupportFiles\\sounder.exe";						// ... this won't need changing
	alias	WAVPath				= "C:\\Thrustmaster\\ED_TargetScript_Warthog\\SupportFiles\\sounds\\";							// ... this won't need changing
	
	//----------//
	// Identity //
	//----------//

	// 'CMDRName' alias is declared here and extracted from MyJournalData.json supporting multiple Elite Dangerous accounts
	// If you don't wish to use this functionality (maybe you only have one account), ENABLE CMDRNameOverride and set your Commander name manually below.
	
	define	CMDRNameOverride	DISABLED  
	alias	MyName 				= "Clicker";

	alias	MyFC				= "X7X-08Z";			// Replace "X7X-08Z" with your Carrier ID if you have one
	alias	MyFCName			= "Clicker's Folly";	// Replace with the name you've given to your Fleetcarrier
	alias	FCOwner				= "Clicker";			// Commander's name who owns the 'MyFC'. Script will assume this CMDR owns this FC.
														// This caters for players with multiple accounts (but only one fleetcarrier)
	//----------------//									
	// MapKey Profile //
	//----------------//

	define	MapKeyProfile		FULL					// Valid Settings are FULL or BASIC 
														// FULL uses all the advanced functions available for Axis, Switches, Triggers and Buttons
														// BASIC sends simple, plain keystrokes...no macro or function calls, no smarts...great for beginners
	//-------------------//
	// Hardware settings //
	//-------------------//

	int 	EnableMyRudder		= ENABLED;				// Set to DISABLED if you do not have a Thrustmaster TFRP or TFRPHA Rudder.

	//--------------//
	// LED settings //
	//--------------//

	int		FlashLEDs			= ENABLED;				// Flash the Status LEDs when status changes. ENABLED or DISABLED
	int		LEDLevel			= 1;					// Default starting LED Level. Valid Levels = 0 - 5. Refer fnLEDBrightness()
														// LEDLevel 0: 0	- 42 (off)
														// LEDLevel 1: 43	- 85 (dimmest)
														// LEDLevel 2: 86	- 128
														// LEDLevel 3: 129 	- 171
														// LEDLevel 4: 172	- 214
														// LEDLevel 5: 215 	- 255 (brightest)

	//----------------//
	// Status.json    //		THIS SECTION IS CRITICAL FOR THE SCRIPT TO WORK
	//----------------//

	// WARNING:		This script relies on and makes extensive use of 'status.json' key values
	//				If the script cannot find status.json, it will abort.

	// NOTE:		Set the 'alias' below to point to the Elite Dangerous journal folder / status.json file
	//				The below path is usually where the Elite Dangerous journal files can be found.
	//				Just replace '<username>' with your Windows username, NOT your CMDR Name!!!
	
	// Set at top in CRITICAL Settings
	// alias	StatusFile			= "d:\\Users\\<username>\\Saved Games\\Frontier Developments\\Elite Dangerous\\status.json";
	// alias	MaxStatusFile		= "d:\\Users\\<username>\\Saved Games\\Frontier Developments\\Elite Dangerous\\NewMaxJson.json";
	
	define	StatusReadRate		500		// Set Read Loop rate in milliseconds. (ie 500 = read status.json twice a second)
										// You may see issues if this is set too small. If you do, raise this value to 750, 1000, or higher

	//----------------//
	//  MyStatusFile  //
	//----------------//

	// NOTE:		Set the 'alias' below to point to where you want to save and load script variables that are not tracked via status.json
	//				I've included an example below but so long as you create the folder structure, you can put this anywhere on your PC
	//				Saves the script states after a game restart or relog. 

	// Set at top in CRITICAL Settings	
	// alias	MyStatusFile		= "C:\\Thrustmaster\\ED_TargetScript_Warthog\\SupportFiles\\Output\\MyWarthogStatusFile.json";

	//---------------//
	// MyJournalData //
	//---------------//
	
	// Set above in CRITICAL Settings
	// alias	MyJournalData			= "C:\\Thrustmaster\\ED_TargetScript_Warthog\\SupportFiles\\Output\\MyJournalData.json";
	
	define	JournalReadRate			300			// Set Read Loop rate in milliseconds. (ie 1000 = one second)
												// You may see issues if this is set too small. If you do, raise this value.
													
	//----------------//
	// Text To Speech //
	//----------------//

	// https://support.microsoft.com/en-nz/help/22805/windows-10-supported-narrator-languages-voices 
	// To make the voices visible to non MS apps, you need to tweak the registry using the method described here;
	// https://www.ghacks.net/2018/08/11/unlock-all-windows-10-tts-voices-system-wide-to-get-more-of-them/
	//
	// I have provided REGSCRAP files to streamline the Registry editing part of the above.
	// Regscrap files may be found within the SupportFiles\TTS Voice Registry Scraps folder of this package
	//   
	// VoiceVolume should be set to the relative volume level (%) 
	// Refer fnTextToSpeech() function in ED_Functions.tmh for usage examples

	int		EnableVoice			= ENABLED;				// ENABLED or DISABLED. Enable this if you wish to use the Text To Speech Feature 
														// Toggled via tgTxt2Speech();
															
	int		VoiceVolume			= 100;					// Default Volume set at 100% Settable via fnVoiceVolume()
														// Note: VoiceVolume gets saved to MyStatus file when game halts and is reloaded at script start
	int		VoiceRate			= 1;					// Slightly faster than default. You can set this using DEBUG + InputCMD
	int		AltVoiceRate		= 1;					// Default. You can set this using DEBUG + InputCMD

	// Run 'voice.exe -l" (lower case L) in a command line to see which voices are installed
	// 'voice.exe' is located under the SupportFiles folder
	// Add or remove the below voices to match what's available on your PC.
	// The below are the voices available and tested on my PC and must be enclosed in quotation marks.
	// I installed these English Language Voice options using instructions via above links then merged the associated regscraps.
	// Regscraps can be found here - C:\Thrustmaster\ED_TargetScript_Warthog\SupportFiles\TTS Voice Registry Scraps

	
	alias	Catherine			= "\"Microsoft Catherine\"";			// Adult, Female,	en-AU
	alias	David				= "\"Microsoft David Desktop\"";		// Adult, Male,		en-US
	alias	Zira				= "\"Microsoft Zira Desktop\"";			// Adult, Female,	en-US 
	alias	Heera				= "\"Microsoft Heera\"";				// Adult, Male,		en-IN
	alias	Ravi				= "\"Microsoft Ravi\"";					// Adult, Female,	en-IN 
	alias 	Susan				= "\"Microsoft Susan\"";				// Adult, Female,	en-GB
	alias	George				= "\"Microsoft George\"";				// Adult, Male,		en-GB	
	alias	Hazel				= "\"Microsoft Hazel Desktop\"";		// Adult, Female,	en-GB
	alias	James				= "\"Microsoft James\"";				// Adult, Male,		en-AU
	alias	Mark				= "\"Microsoft Mark Desktop\"";			// Adult, Male,		en-US																			
	alias	Sean				= "\"Microsoft Sean\"";					// Adult, Male,		en-IE
	alias	Richard				= "\"Microsoft Richard\"";				// Adult, Male,		en-CA
	alias	Linda				= "\"Microsoft Linda\"";				// Adult, Female,	en-CA

	// 'DefaultVoice' and 'AltVoice' MUST BE installed by following the instructions in the links provided above	
	int		DefaultVoice		= &Catherine;			// Set your preferred (installed) voice here
	int		AltVoice			= &James;				// Secondary Voice refer fnTextToSpeech() on usage.
	
	// NOTE:	I have used two or more voices in this script
	//			I recommend that you search the script looking for 'fnTextToSpeech' to check which voices I have used and change if required
	//			Sending a non-installed voice is not a critical error and simply results in TTS not saying anything
	//------------------------//
	// Voice Enabled Training //
	//------------------------//
	
	int	TrainingMode			= ENABLED;					// ENABLED	= When game is not running, pressing a button/switch announces its function and prints same to console.
															// DISABLED	= Training mode announcements and printouts are not sent
	int	AnnounceTraining		= DISABLED;					// DISABLED	= Do not announce when training mode becomes enabled 
															// ENABLED	= Announce training mode when available 

	//------------------//
	// WAV Sound Player //
	//------------------//

	// Refer fnSoundFX() function for usage etc
	// Set SoundPath to where you copied sounder.exe. 
	// Set WAVPath to where you copied any wav files you wish to use
	// Set 'SoundCMD' for any command line arguments you wish to use 
	// Run sounder.exe in a command prompt window (from where you copied it) with no arguments etc to see a list of options
	// sounder.exe utility provided by https://elifulkerson.com/projects/commandline-wav-player.php

	int		EnableSoundFX		= ENABLED;	 				// ENABLED or DISABLED. Enable this if you wish to use "sounder.exe"
	
	// Set at top in CRITICAL Settings
	// alias	SoundPath			= "C:\\Thrustmaster\\ED_TargetScript_Warthog\\SupportFiles\\sounder.exe";
	// alias	WAVPath				= "C:\\Thrustmaster\\ED_TargetScript_Warthog\\SupportFiles\\sounds\\";

	alias	SoundCMD			= "";

	//------------------//
	// AutoHUD Settings //
	//------------------//

	int NVGUI					= OFF;						// Turn HUD GUI off when using Night Vision. Set to OFF (0) to disable.
	int FSDGUI					= ON;						// Turn HUD GUI off when Hyperjump. Set to OFF (0) to disable

	//----------//
	// PIP Mode //
	//----------//

	//	There are 6 PIPModes available.
	//	You may set the Default mode below to one of the following values
	//
	//	0 = Single		1 PIPs per press
	//	1 = Double		2 PIPs per press
	//	2 = Attack		4 PIPs to selected system, 2 PIPs to secondary attack focussed system (ie ENG + WEP focussed) 
	//	3 = Defend		4 PIPs to selected system, 2 PIPs to secondary defend focussed system (ie SYS + ENG focussed)
	//	4 = Recharge	4 PIPs to selected system, 1 PIP to each of the other 2
	//	5 = Gen Purpose	3 PIPs to selected system, 3 PIPs to secondary 
	//
	//	Refer fnPIPManager() function within ED_Functions.tmh for more info.
	
	define DefaultPIPMode		3						// Set this to your preferred PIPMode. Value is set on the fly via H4P (see fnPIPMode() in ED_Functions.tmh)

	//--------------------------//
	// General Status Variables //
	//--------------------------//

	// ENABLE only ONE of the following two settings. AutoHangar takes prescedence over AutoDisembark if both enabled 
	int	AutoHangar				= ENABLED;				//	Enable to initiate Hangar+Station Services automatically when docked, DISABLED = don't
	int AutoDisembark			= DISABLED;				//	Enable to disembark automatically when docked, DISABLED = don't
	
	int	AutoHUD					= ENABLED;				//	Enable to toggle HUD to Analysis Mode when FSD engaged
	int	AutoGearUP				= ENABLED;				//	Enable to retract landing gear when lifting off using fDocked flag
	int	AutoGearDOWN			= DISABLED;				//	Enable to deploy landing gear when docking request is granted
	int	AutoLandingLights		= DISABLED;				//	Enable to turn on Landing Lights when docking request is granted
	int	AutoHeatsink			= ENABLED;				//	Enable to fire a heatsink when temp > 100% (requires launcher and ammo)
	int	AutoStrobe				= DISABLED;				//	Enable to strobe silent running if in danger and shields drop
	int	AutoHONK				= ENABLED;				//	Enable to fire discovery scanner when entering new system
	int	AutoRecall				= ENABLED;				//	Enable to recall fighther if docking request is denied due to active fighter
	int AutoAbort				= DISABLED;				//	Enables Abort() call to stop script 20 seconds after game stops
	int AutoRETRACT				= ENABLED;				//	Enable to retract Landing Gear or Cargo Scoop (if deployed) and we hit boost
	
	int SCOLowFuelFailsafe		= ENABLED;				//	Enable disconnects SCO if Low fuel threshold is met. Disabled risks running out of fuel
	
	int	ChatTABs				= 2;					//	Set to number of Chat Tabs you have setup within the Comms Panel, in game. (Valid = 1-4)

	//--------------------------//
	// Axis Curves and Settings //
	//--------------------------//

	// Refer "Axes" chapter (p27) in the Target Script Editor Basics v1.5 manual for more detail
	// The below constructs support S-Curves

	// Define the deadzones and zoom factor
	// ------------------------------------
	define	Joystick_L_DZ 		0						// Set Joystick Deadzone	Left
	define	Joystick_C_DZ 		1						// Set Joystick Deadzone	Centre
	define	Joystick_R_DZ 		0						// Set Joystick Deadzone	Right
	define	Joystick_Zoom		0						// Set Joystick Zoom factor
	
	define	Rudder_L_DZ			0						// Set Rudder 	Deadzone	Left
	define	Rudder_C_DZ			10						// Set Rudder 	Deadzone	Centre
	define	Rudder_R_DZ			0						// Set Rudder 	Deadzone	Right
	define	Rudder_Zoom			0						// Set Rudder 	Zoom factor
	
	define	Slew_L_DZ			0						// Set Slew 	Deadzone	Left
	define	Slew_C_DZ			15						// Set Slew 	Deadzone	Centre
	define	Slew_R_DZ			0						// Set Slew 	Deadzone	Right
	define	Slew_Zoom			0						// Set Slew 	Zoom factor 

	int	FAOFFCurves				= SLOW;		 			// Set Curve profile desired for FA-OFF. Valid settings = OFF, MILD, MEDIUM or SLOW (see below) 
	int	CurveInfo				= NOPRINT;				// Set if you want curve info printed to console each time we change. Valid settings = PRINT or NOPRINT
	
	int		SwapRoll4Yaw		= DISABLED;				// Set to ENABLED if you wish to set X-Axis to Yaw (Default = Roll)
	
	// The below curve arrays are set for "off", "mild", "medium" or "slow" and controlled via the Autopilot switch
	// Eg 	AP Switch set at APPAT-O	= (Curve = 1)
	//		AP Switch set at APPAT-I	= (Curve = 2)
	//		AP Switch set to APAH		= (Curve = 0)
	//		AP Switch set to APALT-O	= (Curve = 3)
	//		AP Switch set to APALT-I	= (Curve = 4)
	 
	// Define curve & zoom arrays
	// --------------------------   APPAT-O	APPAT-I	APAH	APALT-O	APALT-I	// Used within fnSetCurves() and applied to JS, Rudder and Slew  (x, y & z axis)
	short	Joystick_Curve[] 	= {	1,		2,		0,		3,		4 };	// Autopilot switch (Up = MILD curves, down = SLOWER curves)
	
	short	Rudder_Curve[]		= { 1,		2,		0,		3,		4 };	// Autopilot switch (Up = MILD curves, down = SLOWER curves)
	 
	short	Slew_Curve[]		= {	2,		2,		0,		2,		2 };	// Set Slew Curve
	// --------------------------  MILD	  MEDIUM   NONE    SLOW   SLOWEST	//

	// END