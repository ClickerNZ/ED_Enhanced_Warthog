	//	Usage:		PSF+EFLNORM calls this function

	// --- GLOBALS
	int DebugFunction = "Reset Controllers";		// Print to console at script run time
		
	int fnDEBUG(int dummy = 0) {
		int fnName = "fnDebug";
		int reason = 0;
		
		// Issue: joystick unresponsive
		if (DEBUG > 0) {
			fnVPOutput("DEBUG: Reinitialising controllers", 0, 2);					// DEBUG message
			
			initJoystickAxis();
			initThrottleAxis();
			initSliderAxis();
			initSlewAxis();
			initRudderAxis();
			initCurves(NONE, PRINT, YES, FALSE);									// Parameters: Curve profile=NONE, Print to console=NO, TTS Announce= YES, Save Curves = FALSE 
		}
		else reason = "Debug must be set greater than 0";
		
		if (reason != 0) fnNotValid(fnName, reason);
	}


	//	FUNCTION:	Find substring within a string and return first char position or -1 if not found
	//	NOTE:		sys.tmh has strstr() listed to provide this functionality, however it seems to always
	//				return a '0' no matter what you plug in. So, I decided to write my own.
	
	int findstr(alias string, alias substring) {
	
		int substrlen	= strlen(&substring);
		int strstart	= 0;
		int	strend		= strlen(&string) - substrlen;
		
		char mystr;
		Dim(&mystr, substrlen+1);
		mystr[0]=NUL;
		
		while (strstart <= strend) {
			strsub(&mystr, &string, strstart, strstart+substrlen);
			mystr[substrlen] = NUL;									// nul terminate char array
			if (strcmp(&mystr, &substring) == 0) return strstart;	// return position of substring within string
			strstart = strstart + 1;
		}
		return -1;													// substring not found
	}


	//	FUNCTION:	TARGET does not have a strcpy(){} mapped function in sys.tmh
	//				Copies src string to dst string 
	//	Parameters:	&dst	- Destination string to copy into
	//				&src	- Source string to copy from 
	
	int strcpy(alias dst, alias src) {
		sprintf(&dst, "%s", &src);
	}
	
