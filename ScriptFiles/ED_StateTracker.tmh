	//	FUNCTION:	Grab 'Modules' key value from MyJournalData.json and decode into individual flags
	//	Parameters:	dummy - enables REXEC and DeferCall
	//	Usage:		Called from stfnProcessMyJournalData()
	
	int stfnDecodeModules(int dummy = 0) {

		Modules = stfnGetKeyValue("Modules", INTEGER, 1);

//		if (DEBUG >= LOG) printf("!!	DEBUG: stfnDecodeModules() - Modules key-value = %d\x0a", Modules);

		// "lFlagName" is "Last" or previous flag value							// Allows us to track each time a flag is toggled 
		lSCOPresent				=	fSCOPresent;								// Granular level - which module bits have changed
		lFighterPresent			= 	fFighterPresent;
		lSRVPresent				=	fSRVPresent;
		lHeatsinkPresent		=	fHeatsinkPresent;
		lChaffLauncherPresent	=	fChaffLauncherPresent;
		lSCBPresent				=	fSCBPresent;
		lECMPresent				=	fECMPresent;
		lLimpetPresent			=	fLimpetPresent;

		fSCOPresent				=	((Modules & ED_SCOPresent) > 0);			// 'ED_...' masks defined within 'ED_ScriptDefines' file 
		fFighterPresent			=	((Modules & ED_FighterPresent) > 0);
		fSRVPresent				=	((Modules & ED_SRVPresent) > 0);
		fHeatsinkPresent		=	((Modules & ED_HeatsinkPresent) > 0);
		fChaffLauncherPresent	=	((Modules & ED_ChaffLauncherPresent) > 0);
		fSCBPresent				=	((Modules & ED_SCBPresent) > 0);
		fECMPresent				=	((Modules & ED_ECMPresent) > 0);
		fLimpetPresent			=	((Modules & ED_LimpetPresent) > 0);
				
	}


	//	FUNCTION:	Process key-values found within MyJournalData.json
	//	Parameters: dummy - enables calls from REXEC() and DeferCall() 
	//	Usage:
	
	int stfnProcessMyJournalData(int dummy = 0) {

	// MyJournalData.json contains the following key-value pairs...
	// timestamp (STRING), LoadGameDetect (INTEGER), **CMDRName (STRING), ShipName (STRING), ShipType (STRING), **StationName (STRING), StationType (STRING), SystemName (STRING),
	// BodyName (STRING), OrganicFound (STRING), **DockingStatus (STRING), **DeniedReason (STRING), **LandingPad (INTEGER), **Modules (INTEGER), **ActiveFighter (BOOLEAN),
	// **InputCMD (STRING), **CMDParameter (STRING)

	// Time critical keys should be trapped here, otherwise create a standalone function to process
	// Keys marked with ** are decoded within existing functions 
		
			stfnDecodeModules(0);																	// Individual flags used to enable trigger and switch functions etc
			fnFighterStatus(0);																		// Determines if Fighter is active 
			LoadGameDetect = stfnGetKeyValue("LoadGameDetect", INTEGER, 1);

//-		DEVELOPMENT CODE - REMOVE BELOW FROM HERE...
/*
		if (DEBUG >= LOG) {
			if (fSCOPresent)			printf("!!	DEBUG: stfnProcessMyJournalData() - SCO FSD installed\x0a");
			if (fFighterPresent)		printf("!!	DEBUG: stfnProcessMyJournalData() - Fighter Bay installed\x0a");
			if (fSRVPresent)			printf("!!	DEBUG: stfnProcessMyJournalData() - SRV Bay installed\x0a");	
			if (fHeatsinkPresent)		printf("!!	DEBUG: stfnProcessMyJournalData() - Heatsink Launcher installed\x0a");
			if (fChaffLauncherPresent)	printf("!!	DEBUG: stfnProcessMyJournalData() - Chaff Launcher installed\x0a");
			if (fSCBPresent)			printf("!!	DEBUG: stfnProcessMyJournalData() - Shield Cell Bank installed\x0a");
			if (fECMPresent)			printf("!!	DEBUG: stfnProcessMyJournalData() - Electronic Counter Measure installed\x0a");
			if (fLimpetPresent)			printf("!!	DEBUG: stfnProcessMyJournalData() - Limpet controller installed\x0a");
			if (ActiveFighter)			printf("!!	DEBUG: stfnProcessMyJournalData() - Fighter is ACTIVE\x0a");
			printf("\x0a");
		}
*/			
		// Check if InputCMD or CMDParameter have changed...
		if (InputCMDcharsSET == 0) {			// Dimension and clear char arrays...
			Dim(&InputCMD, 64);					// Arbitrary buffer size
			InputCMD[0] = 0;
			
			Dim(&lastInputCMD, 64);				// To track when InputCMD changes 
			lastInputCMD[0] = 0;				// Copied from &InputCMD within fnInputCMD()
			
			Dim(&CMDParameter, 64);				// Arbitrary buffer size
			CMDParameter[0] = 0;
			
			Dim(&lastCMDParameter, 64);			// To track if CMDParameter changes
			lastCMDParameter[0] = 0;			// Copied from CMDParameter within fnInputCMD()
			
			InputCMDcharsSET = 1;
		}

		strcpy(&InputCMD, stfnGetKeyValue("InputCMD", STRING, 1));
		InputCMD[strlen(&InputCMD)] = 0;
		
		strcpy(&CMDParameter, stfnGetKeyValue("CMDParameter", STRING, 1));
		CMDParameter[strlen(&CMDParameter)] = 0;

		if (strcmp(&InputCMD, "not set") == 0) {
//-			if (DEBUG >= LOG) printf("!!	DEBUG: stfnProcessMyJournalData() - InputCMD = not set, do not call fnInputCMD()\x0a");
		}
		else {
			if (strcmp(&InputCMD, &lastInputCMD) == 0 & strcmp(&CMDParameter, &lastCMDParameter) == 0)	{	// New inputCMD to process?
//-				if (DEBUG >= LOG) printf("!!	DEBUG: stfnProcessMyJournalData() - InputCMD and CMDParameter have no changes, do not call fnInputCMD()\x0a");
			}
			else{
//-				if (DEBUG >= LOG) printf("!!	DEBUG: stfnProcessMyJournalData() - InputCmd or CMDParameter have changed\x0a");
				fnInputCMD(0);
			}
		}
			
//-		DEVELOPMENT CODE - REMOVE ABOVE HERE

	}

	
	// FUNCTION: Read and process 'GuiFocus' key value in status.json

	int stfnProcessGuiFocus() {
		int GUIFocus;
		int GUITxt = "not defined";

//-		if (Flags != 0) {										// Hmmmm'k ... maybe GameLoaded or !StartupLock 
		if (GameLoaded) {
			GUIFocus = stfnGetKeyValue("GuiFocus", INTEGER);
			// Not too sure of the value of this - to be reviewed	-	REVIEW 
			if (GUIFocus == GUI_FSSMode) {
				FSSMode = ON;
			}
			else FSSMode = OFF;
			
			if (GUIFocus == GUI_SAAMode) {
				SAAMode = ON;
			}
			else {
				SAAMode = OFF;
			}
			
			if (DEBUG >= LOG) {
				if (GUIFocus == 0) GUITxt = "No Focus";
				else if (GUIFocus == 1) GUITxt	= "RH Panel";
				else if (GUIFocus == 2) GUITxt	= "LH Panel";
				else if (GUIFocus == 3) GUITxt	= "Comms Panel (top)";
				else if (GUIFocus == 4) GUITxt	= "Role Panel (bottom)";
				else if (GUIFocus == 5) GUITxt	= "Station Services";
				else if (GUIFocus == 6) GUITxt	= "Galaxy Map";
				else if (GUIFocus == 7) GUITxt	= "System Map";
				else if (GUIFocus == 8) GUITxt	= "Orrery";
				else if (GUIFocus == 9) GUITxt	= "FSS Mode";
				else if (GUIFocus == 10) GUITxt	= "SAA Mode";
				else if (GUIFocus == 11) GUITxt	= "Codex";
				else if (GUIFocus > 11) GUITxt	= "New GUI Mode";
				printf ("!!	DEBUG: stfnProcessGuiFocus() - GUI Mode = (%d) %s\x0a", GUIFocus, GUITxt);
			}
			
			return GUIFocus;
		}
		else {
			return -1;
		}
	}


	// FUNCTION: Initial check to see if game is already running after we've restarted the script.

	int stfnStartCheck() {
	
		int fp;								// file pointer (handle)
		int json100;						// status.json string length - Most Significant Bit (Hundreds) 
		int json10;							// status.json string length - Middle Significant Bit (Tens)
		int json1;							// status.json string length - Least Significant Bit (Ones)
		
		char jason; 
		Dim(&jason, 16);
		jason[0] = 0;		

		fp = fopen(&StatusFile, "r");		// Open status.json if found, otherwise throw an error and abort script 
		if (fp) {
			fclose(fp);
		}
		else {
			printf("\x0a\x0a\!!	FATAL ERROR	!!\x0a\x0a");
			printf("!!	status.json file not found.\x0a\x0a");
			printf("!!	Please set 'StatusFile' alias correctly in ED_UserSettings file\x0a");
			printf("!!	Refer ED_UserSettings.tmh file for instructions.\x0a");
			fnSoundFX("wstop");
			Abort();
		}
		
		stfnReadStatusJson();																	// Read status.json first time before starting loop. Won't work otherwise. I don't know why.
		ActKey(KEYON+REXEC(hReadStatusJson, StatusReadRate, "stfnReadStatusJson();", RNOSTOP));	// Start perpetual loop to read status.json. StatusReadRate is set in ED_UserSettings file

		if (strlen(&myJson) >= 68) {															// Min string length of status.json is 68 and "Flags: 0" when game is not running
			if(Flags == 0) {
				printf("++	Waiting for Game to load...\x0a");	
				printf("\x0a\++	Script initialised and running @ %s \x0a", fnGetTOD());
				
				// Tracking max string length of status.json to ensure read buffer is big enough.
				if (DEBUG >= LOG ) printf("\x0a\++	DEBUG: fnStartCheck() - Max json length seen = %d ...\x0a\x0a", NewMaxJson);
				// If you see errors, ensure 'buf' is set to a value exceeding this number at start of stfnReadStatusJson(), above.
				
				json100 = (NewMaxJson - (NewMaxJson % 100))/100;
				json10	= (NewMaxJson % 100) / 10;
				json1 	= (NewMaxJson % 100) % 10;

//-				sprintf(&jason, "jason %d %d%d", json100, json10, json1);						// Speaks each digit
//-				fnTextToSpeech(&jason);
				
				fnTextToSpeech("Waiting for game to load");
			}
			fnSoundFX("tada", 75);																// Script has started successfully 
		}
		
//-		TEST AREA --- Copy code below here to test at end of script start
/*		
		printf("\x0a+++++ TEST AREA +++++\x0a\x0a");

		printf("Origin Station: %s\x0a", &oStation);
		
		printf("\x0a+++++ TEST AREA +++++\x0a");
*/	
//-		TEST AREA --- Copy code above here to test at end of script start

	}


	// FUNCTION:	Save certain global variables and states not included in status.json
	// PURPOSE:		Save current status of certain variables when mode switching or restarting the game
	// REQUIRES:	'MyStatusFile' path must be set correctly within ED_UserSettings.tmh file
	// PARAMETERS:	action = SAVE or LOAD

	// Global declarations for stfnMyStates()
		
	char MyStatesJson;													// json string containing our key-value pairs
	
	int stfnMyStates(int action) {

		int fnName = "MyStates";
		int reason = 0;
		int UserSettings;												// Binary encoded user settings
		int fh;															// General File Pointer Variable 
		int rc;
		int fpresult;
		int buf = 1024;													// Increase buf when required
		int mySIZE;
		
		Dim(&MyStatesJson, buf);
		MyStatesJson[0] = 0;
		
		if (action == SAVE)	{

			UserSettings = fnEncodeUserSettings(0);
			
//			sprintf(&MyStatesJson, "{\"ShipDismissed\":%d,\"NewMaxJson\":%d,\"VoiceVolume\":%d,\"VoiceRate\":%d,\"AltVoiceRate\":%d,\"ChatTABs\":%d,\"FAOFFCurves\":%d,\"OldCurves\":%d,\"LEDLevel\":%d,\"PIPMode\":%d,\"ThrustUpTime\":%d,\"PrivateGroup\":%d,\"UserSettings\":%d}", ShipDismissed, NewMaxJson, VoiceVolume, VoiceRate, AltVoiceRate, ChatTABs, FAOFFCurves, OldCurves, LEDLevel, PIPMode, ThrustUpTime, PrivateGroup, UserSettings);
			sprintf(&MyStatesJson, "{\"NewMaxJson\":%d,\"VoiceVolume\":%d,\"VoiceRate\":%d,\"AltVoiceRate\":%d,\"ChatTABs\":%d,\"FAOFFCurves\":%d,\"OldCurves\":%d,\"LEDLevel\":%d,\"PIPMode\":%d,\"ThrustUpTime\":%d,\"PrivateGroup\":%d,\"UserSettings\":%d}", NewMaxJson, VoiceVolume, VoiceRate, AltVoiceRate, ChatTABs, FAOFFCurves, OldCurves, LEDLevel, PIPMode, ThrustUpTime, PrivateGroup, UserSettings);
			mySIZE = strlen(&MyStatesJson);
			if (mySIZE > buf) {
				reason = "Buffer size too small";
				goto EndOfSave;
			}
			MyStatesJson[mySIZE] = 0;
						
			fh = fopen(&MyStatusFile, "w");								// creates the file if it doesn't exist (refer ED_UserSettings.tmh for filename and path 
			
			if (fh) {
				fpresult = fwrite(&MyStatesJson, mySIZE, 1, fh);
				fclose(fh);
				
				if (fpresult == -1) {
					fnVPOutput("Error writing MyStates to status file", 100, 2);
				}	
				else {
					printf("++	MyStates successfully saved @ %s\x0a", fnGetTOD());
					
					if (DEBUG > 0) {
						printf("=====================================\x0a\x0a");
//						printf("	ShipDismissed		= %d\x0a", ShipDismissed);
						printf("	NewMaxJson		= %d\x0a", NewMaxJson);
						printf("	VoiceVolume		= %d\x0a", VoiceVolume);
						printf("	VoiceRate		= %d\x0a", VoiceRate);
						printf("	AltVoiceRate		= %d\x0a", AltVoiceRate);
						printf("	ChatTABs		= %d\x0a", ChatTABs);
						printf("	FAOFFCurves		= %d\x0a", FAOFFCurves);
						printf("	OldCurves		= %d\x0a", OldCurves);
						printf("	LEDLevel		= %d\x0a", LEDLevel);
						printf("	PIPMode		= %d\x0a", PIPMode); 
						printf("	ThrustUpTime		= %d\x0a", ThrustUpTime);
						printf("	PrivateGroup		= %d\x0a", PrivateGroup);
						printf("	UserSettings		= %d\x0a\x0a", UserSettings);
						printf("=====================================\x0a\x0a");
					}
				}
			}
			else {
				fnTextToSpeech("Error writing to My Status File");
				printf("!!	Error opening file to write @ %s: %s\x0a", fnGetTOD(), &MyStatusFile);
			}
			EndOfSave:
		}
		
		else if (action == LOAD) {

			fh = fopen(&MyStatusFile, "r");								// open file to read
			
			if (fh) {

				Dim(&MyStatesJson, buf);
				MyStatesJson[0] = NUL;

				fpresult = fread(&MyStatesJson, 1, buf, fh);			// Load MyStates from file				
				fclose(fh);
				
				if (fpresult > 0) {	// Read from file was successful

					// Extract our variables from our struct array
//					ShipDismissed	= stfnGetKeyValue("ShipDismissed", INTEGER, 2);
					NewMaxJson		= stfnGetKeyValue("NewMaxJson", INTEGER, 2);
					VoiceVolume		= stfnGetKeyValue("VoiceVolume", INTEGER, 2);
					VoiceRate		= stfnGetKeyValue("VoiceRate", INTEGER, 2);
					AltVoiceRate	= stfnGetKeyValue("AltVoiceRate", INTEGER, 2);
					ChatTABs		= stfnGetKeyValue("ChatTABs", INTEGER, 2);
					FAOFFCurves		= stfnGetKeyValue("FAOFFCurves", INTEGER, 2);
					OldCurves		= stfnGetKeyValue("OldCurves", INTEGER, 2);
					LEDLevel		= stfnGetKeyValue("LEDLevel", INTEGER, 2);
					PIPMode			= stfnGetKeyValue("PIPMode", INTEGER, 2);
					ThrustUpTime	= stfnGetKeyValue("ThrustUpTime", INTEGER, 2);
					PrivateGroup	= stfnGetKeyValue("PrivateGroup", INTEGER, 2);
					UserSettings	= stfnGetKeyValue("UserSettings", INTEGER, 2);

					if (DEBUG > 0) {
						printf("\x0a\++	MyStates successfully loaded @ %s\x0a", fnGetTOD());
						printf("=====================================\x0a");
//						printf("	ShipDismissed		= %d\x0a", ShipDismissed);
						printf("	NewMaxJson		= %d\x0a", NewMaxJson);
						printf("	VoiceVolume		= %d\x0a", VoiceVolume);
						printf("	VoiceRate		= %d\x0a", VoiceRate);
						printf("	AltVoiceRate		= %d\x0a", AltVoiceRate);
						printf("	ChatTABs		= %d\x0a", ChatTABs);
						printf("	FAOFFCurves		= %d\x0a", FAOFFCurves);
						printf("	OldCurves		= %d\x0a", OldCurves);
						printf("	LEDLevel		= %d\x0a", LEDLevel);
						printf("	PIPMode		= %d\x0a", PIPMode); 
						printf("	ThrustUpTime		= %d\x0a", ThrustUpTime);
						printf("	PrivateGroup		= %d\x0a", PrivateGroup);
						printf("	UserSettings		= %d\x0a", UserSettings);
						printf("====================================\x0a\x0a");
					}
				
					if (UserSettings != defUserSettings) {
						fnDecodeUserSettings(UserSettings);
					}
					if ((UserSettings != defUserSettings) | (fnCompareIntSettings(0))) {		// Print delta to console if settings are not same as ED_UserSettings.tmh
						fnTextToSpeech("User settings not default");
						fnUserSettingsDelta(0);
					}
				}
				else {
					fnVPOutput("Error reading MyStates from status file", 100, 2);
				}
			}
			else {
				fnTextToSpeech("Non fatal error, my Status File not found or invalid, check con sole message"); 
				printf("\x0a\!!	Non-Fatal Error opening file to read: %s\x0a", &MyStatusFile);
			}
		}		
		else {
			reason = "action not valid";
			printf("++	stfnMyStates Action = %d\x0a", action);
		}
		if (reason != 0) fnNotValid(fnName, reason);
	}

	// END
